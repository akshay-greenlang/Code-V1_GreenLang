{
  "name": "greenlang-monorepo",
  "version": "0.3.0",
  "description": "GreenLang Climate OS: auditable climate data foundation and compliance applications, with Factors as the current hardened foundation",
  "private": true,
  "workspaces": [
    "frontend",
    "frontend/packages/*",
    "greenlang/factors/sdk/ts"
  ],
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "test:unit": "turbo run test:unit",
    "test:integration": "turbo run test:integration",
    "test:e2e": "turbo run test:e2e",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "type-check": "turbo run type-check",
    "format": "turbo run format",
    "dev": "turbo run dev --parallel",
    "dev:greenlang": "turbo run dev --filter=@greenlang/frontend",
    "dev:vcci": "turbo run dev --filter=@greenlang/vcci-scope3-frontend",
    "dev:cbam": "turbo run dev --filter=@greenlang/cbam-frontend",
    "dev:csrd": "turbo run dev --filter=@greenlang/csrd-frontend",
    "deploy": "turbo run deploy",
    "docker:build": "turbo run docker:build",
    "coverage": "turbo run coverage",
    "security:scan": "turbo run security:scan",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "graph": "turbo run build --graph=dependency-graph.html"
  },
  "devDependencies": {
    "turbo": "^1.11.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0",
    "python": ">=3.11.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/akshay-greenlang/Code-V1_GreenLang.git"
  },
  "keywords": [
    "greenlang",
    "carbon-accounting",
    "sustainability",
    "climate-tech",
    "monorepo",
    "turborepo"
  ],
  "author": "GreenLang Team <support@greenlang.ai>",
  "license": "Apache-2.0"
}
