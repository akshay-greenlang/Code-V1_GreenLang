  "info": {
    "description": "Canonical climate reference layer. Resolve emissions factors with full provenance, version pinning, and signed receipts. Every factor response includes an `explain` block by default; pass `?compact=true` to opt out. See https://developers.greenlang.ai.",
    "title": "GreenLang Factors API",
    "version": "1.0.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/v1/factors": {
      "get": {
        "description": "Read-only listing of every factor visible to the alpha tier. Filtering is the alpha-spec subset only: by geography URN, source URN, pack URN, category enum, and vintage window. Pagination is cursor-based (opaque next_cursor; pass it back verbatim). Resolve / explain payloads are intentionally excluded.",
        "operationId": "list_factors_v1_factors_get",
        "parameters": [
          {
            "description": "Filter by geography URN.",
            "in": "query",
            "name": "geography_urn",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Filter by geography URN.",
              "title": "Geography Urn"
            }
          },
          {
            "description": "Filter by source URN.",
            "in": "query",
            "name": "source_urn",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Filter by source URN.",
              "title": "Source Urn"
            }
          },
          {
            "description": "Filter by factor pack URN.",
            "in": "query",
            "name": "pack_urn",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Filter by factor pack URN.",
              "title": "Pack Urn"
            }
          },
          {
            "description": "One of ['scope1', 'scope2_location_based', 'scope2_market_based', 'grid_intensity', 'fuel', 'refrigerant', 'fugitive', 'process', 'cbam_default'].",
            "in": "query",
            "name": "category",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "One of ['scope1', 'scope2_location_based', 'scope2_market_based', 'grid_intensity', 'fuel', 'refrigerant', 'fugitive', 'process', 'cbam_default'].",
              "title": "Category"
            }
          },
          {
            "description": "ISO date; only factors with vintage_start > this.",
            "in": "query",
            "name": "vintage_start_after",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "ISO date; only factors with vintage_start > this.",
              "title": "Vintage Start After"
            }
          },
          {
            "description": "ISO date; only factors with vintage_end < this.",
            "in": "query",
            "name": "vintage_end_before",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "ISO date; only factors with vintage_end < this.",
              "title": "Vintage End Before"
            }
          },
          {
            "description": "Opaque pagination cursor.",
            "in": "query",
            "name": "cursor",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Opaque pagination cursor.",
              "title": "Cursor"
            }
          },
          {
            "description": "Page size (1-200).",
            "in": "query",
            "name": "limit",
            "required": false,
            "schema": {
              "default": 50,
              "description": "Page size (1-200).",
              "maximum": 200,
              "minimum": 1,
              "title": "Limit",
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FactorListResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "List factors (cursor-paginated, filtered)",
        "tags": [
          "factors-v0.1-alpha"
        ]
      }
    },
    "/v1/factors/by-alias/{legacy_id}": {
      "get": {
        "description": "Resolve a legacy ``EF:...`` (or custom) factor identifier to its canonical record via the ``factor_aliases`` table. Returns the same shape as ``/v1/factors/{urn}``; the response carries the canonical ``urn`` as the primary id and ``factor_id_alias`` as a sibling.\n\n404 with a stable JSON error body if no alias matches the legacy id. The alias path is only available against the real ``alpha_factor_repo`` (Phase 2 V501); the legacy ``factors_service`` fallback returns 404 because alias resolution is not part of that contract.",
        "operationId": "get_factor_by_alias_v1_factors_by_alias__legacy_id__get",
        "parameters": [
          {
            "description": "Legacy factor identifier (e.g. ``EF:US:grid:eGRID-SERC:2024:v1``). URL-encoded path segments are accepted.",
            "in": "path",
            "name": "legacy_id",
            "required": true,
            "schema": {
              "description": "Legacy factor identifier (e.g. ``EF:US:grid:eGRID-SERC:2024:v1``). URL-encoded path segments are accepted.",
              "title": "Legacy Id",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FactorV0_1"
                }
              }
            },
            "description": "Successful Response"
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "No alias matched the supplied legacy id."
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Get one factor by legacy alias (Phase 2 / WS2)",
        "tags": [
          "factors-v0.1-alpha"
        ]
      }
    },
    "/v1/factors/{urn}": {
      "get": {
        "description": "URL-encoded canonical URN (urn:gl:factor:<source>:<ns>:<id>:v<n>). Returns a 404 with a stable JSON error body if the URN is unknown in the active edition.",
        "operationId": "get_factor_v1_factors__urn__get",
        "parameters": [
          {
            "description": "URL-encoded factor URN.",
            "in": "path",
            "name": "urn",
            "required": true,
            "schema": {
              "description": "URL-encoded factor URN.",
              "title": "Urn",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FactorV0_1"
                }
              }
            },
            "description": "Successful Response"
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Factor not found in the active edition."
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Get one factor by URN",
        "tags": [
          "factors-v0.1-alpha"
        ]
      }
    },
    "/v1/healthz": {
      "get": {
        "description": "Unauthenticated liveness probe for v0.1 alpha. Returns the active release profile, the schema id every factor record validates against, the active edition id (when a catalog is loaded), and the build commit SHA when available.",
        "operationId": "healthz_v1_healthz_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthzResponse"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Service health + edition id",
        "tags": [
          "factors-v0.1-alpha"
        ]
      }
    },
    "/v1/packs": {
      "get": {
        "description": "One synthetic pack per alpha source until task #2 publishes the full pack registry. Filtering by source_urn returns only that source's packs.",
        "operationId": "list_packs_v1_packs_get",
        "parameters": [
          {
            "description": "Filter by source URN.",
            "in": "query",
            "name": "source_urn",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Filter by source URN.",
              "title": "Source Urn"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PackListResponse"
                }
              }
            },
            "description": "Successful Response"
          },
