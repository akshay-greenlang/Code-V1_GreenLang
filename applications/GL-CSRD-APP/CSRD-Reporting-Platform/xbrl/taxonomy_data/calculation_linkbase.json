  "validation_rules": {
    "sum_consistency": {
      "description": "Parent value must equal sum of weighted children within tolerance",
      "tolerance_absolute": 0.01,
      "tolerance_relative": 0.001,
      "severity": "ERROR"
    },
    "ratio_consistency": {
      "description": "Ratio calculations must be consistent with components",
      "tolerance_absolute": 0.01,
      "severity": "WARNING"
    },
    "sign_consistency": {
      "description": "All emission values should be non-negative",
      "allowed_negative": ["E1_E17_001"],
      "severity": "ERROR"
    },
    "percentage_range": {
      "description": "Percentage values must be between 0 and 1 (or 0 and 100)",
      "applicable_types": ["xbrli:pureItemType"],
      "min_value": 0.0,
      "max_value": 1.0,
      "severity": "WARNING"
    }
  }
}
