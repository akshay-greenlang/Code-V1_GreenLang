{
  "metadata": {
    "description": "EFRAG ESRS Calculation Linkbase - parent-child sum relationships with weights",
    "version": "2024.1.0",
    "tolerance": 0.01,
    "notes": "Weight +1 indicates additive; weight -1 indicates subtractive. Validation tolerance is 0.01 (absolute difference)."
  },
