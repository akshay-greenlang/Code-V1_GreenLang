{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "API Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(greenlang_factors_api_requests_total[5m])) by (method, path)",
          "legendFormat": "{{method}} {{path}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "title": "API Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(greenlang_factors_api_latency_seconds_bucket[5m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(greenlang_factors_api_latency_seconds_bucket[5m]))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(greenlang_factors_api_latency_seconds_bucket[5m]))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "Error Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(greenlang_factors_api_requests_total{status=~\"5..\"}[5m])) / sum(rate(greenlang_factors_api_requests_total[5m]))",
          "legendFormat": "Error Rate"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "thresholds": { "steps": [
          { "color": "green", "value": null },
          { "color": "yellow", "value": 0.01 },
          { "color": "red", "value": 0.05 }
        ]}}
      }
    },
    {
      "title": "Search Results Distribution",
      "type": "histogram",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "rate(greenlang_factors_search_results_count_bucket[5m])",
          "legendFormat": "{{le}}"
        }
      ]
    },
    {
      "title": "Top-1 Match Confidence",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(greenlang_factors_match_score_top1_bucket[5m]))",
          "legendFormat": "Median Confidence"
        },
        {
          "expr": "histogram_quantile(0.10, rate(greenlang_factors_match_score_top1_bucket[5m]))",
          "legendFormat": "p10 Confidence"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percentunit" }
      }
    },
    {
      "title": "Edition Factor Count",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "greenlang_factors_edition_factor_count",
          "legendFormat": "{{edition_id}} ({{status}})"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "title": "Ingestion Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "sum(rate(greenlang_factors_ingestion_rows_total[5m])) by (source_id, status)",
          "legendFormat": "{{source_id}} ({{status}})"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "rowsps" }
      }
    },
    {
      "title": "Watch Source Changes",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 24 },
      "targets": [
        {
          "expr": "sum(increase(greenlang_factors_watch_source_changes_total[1h])) by (source_id, change_type)",
          "legendFormat": "{{source_id}}: {{change_type}}"
        }
      ]
    },
    {
      "title": "QA Gate Failures",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 24 },
      "targets": [
        {
          "expr": "increase(greenlang_factors_qa_gate_failures_total[24h])",
          "legendFormat": "{{gate_name}}"
        }
      ]
    },
    {
      "title": "Health Status",
      "type": "stat",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 32 },
      "targets": [
        {
          "expr": "up{job=\"factors-service\"}",
          "legendFormat": "Factors Service"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ]
        }
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["greenlang", "factors", "emission-factors"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "utc",
  "title": "GreenLang Factors Catalog",
  "uid": "greenlang-factors-catalog",
  "version": 1
}
