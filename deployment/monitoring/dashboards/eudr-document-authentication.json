    {
      "title": "Fraud Alerts by Severity",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 5, "x": 0, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum by (severity) (increase(gl_eudr_dav_fraud_alerts_total[1h]))", "legendFormat": "{{severity}}" }
