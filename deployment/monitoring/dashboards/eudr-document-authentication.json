      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(increase(gl_eudr_dav_documents_processed_total[24h]))", "legendFormat": "24h" },
        { "expr": "sum(gl_eudr_dav_documents_processed_total)", "legendFormat": "Total" }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      }
    },
    {
      "title": "Classification Accuracy",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(gl_eudr_dav_classifications_total{confidence_level=\"high\"}) / sum(gl_eudr_dav_classifications_total) * 100", "legendFormat": "High Confidence %" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
