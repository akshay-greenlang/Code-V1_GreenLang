        { "expr": "histogram_quantile(0.99, sum(rate(gl_eudr_pav_processing_duration_seconds_bucket{environment=\"$environment\", operation=\"buffer_check\"}[5m])) by (le))", "legendFormat": "p99 (buffer_check)" },
