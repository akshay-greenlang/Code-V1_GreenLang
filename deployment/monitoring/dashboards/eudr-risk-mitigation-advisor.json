{
  "annotations": { "list": [] },
  "description": "AGENT-EUDR-025: Risk Mitigation Advisor (RMA) -- ML-powered mitigation strategy recommendation, remediation plan management, supplier capacity building, 500+ mitigation measure library, effectiveness tracking with ROI analysis, continuous monitoring with adaptive management, cost-benefit budget optimization, multi-stakeholder collaboration, and audit-ready mitigation documentation for EUDR Articles 8, 10, 11, 29, 31 and ISO 31000:2018 compliance",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "Strategy Recommendation",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "title": "Strategy Recommendations Rate",
      "description": "Rate of mitigation strategy recommendations generated by mode (ML vs deterministic) over time. Tracks Engine 1 throughput.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "sum(rate(gl_eudr_rma_strategies_recommended_total{environment=\"$environment\", risk_category=~\"$risk_category\"}[5m])) * 3600", "legendFormat": "Total (/hr)" },
        { "expr": "sum(rate(gl_eudr_rma_strategies_recommended_total{environment=\"$environment\", mode=\"ml\"}[5m])) * 3600", "legendFormat": "ML (/hr)" },
        { "expr": "sum(rate(gl_eudr_rma_strategies_recommended_total{environment=\"$environment\", mode=\"deterministic\"}[5m])) * 3600", "legendFormat": "Deterministic (/hr)" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "drawStyle": "line",
            "pointSize": 5,
            "stacking": { "mode": "none" },
            "spanNulls": false,
            "lineInterpolation": "smooth"
          }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Total (/hr)" }, "properties": [{ "id": "color", "value": { "fixedColor": "white", "mode": "fixed" } }, { "id": "custom.lineWidth", "value": 3 }, { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 5] } }] }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "title": "ML vs Deterministic Mode Split",
      "description": "Proportion of strategy recommendations generated by ML model versus deterministic fallback. High deterministic ratio may indicate model degradation.",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "sum(increase(gl_eudr_rma_strategies_recommended_total{environment=\"$environment\", mode=\"ml\"}[24h]))", "legendFormat": "ML" },
        { "expr": "sum(increase(gl_eudr_rma_strategies_recommended_total{environment=\"$environment\", mode=\"deterministic\"}[24h]))", "legendFormat": "Deterministic" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["value"] },
        "tooltip": { "mode": "single" },
        "pieType": "donut",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "title": "Strategy Recommendation by Risk Category",
      "description": "Distribution of strategy recommendations across 8 EUDR risk categories in the last 24 hours.",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "sum by (risk_category) (increase(gl_eudr_rma_strategies_recommended_total{environment=\"$environment\"}[24h]))", "legendFormat": "{{risk_category}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" },
        "orientation": "horizontal",
        "barWidth": 0.7
      }
    },
    {
      "title": "Strategy Recommendation Latency (p50/p95/p99)",
      "description": "Latency percentiles for mitigation strategy recommendation (Engine 1). Target: p99 < 2 seconds.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(gl_eudr_rma_strategy_recommendation_seconds_bucket{environment=\"$environment\"}[5m])) by (le))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum(rate(gl_eudr_rma_strategy_recommendation_seconds_bucket{environment=\"$environment\"}[5m])) by (le))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum(rate(gl_eudr_rma_strategy_recommendation_seconds_bucket{environment=\"$environment\"}[5m])) by (le))", "legendFormat": "p99" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "thresholdsStyle": { "mode": "line" }
          },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 2 }
            ]
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "title": "ML Model Confidence",
      "description": "Average ML model confidence score for strategy recommendations. Below 0.7 triggers deterministic fallback.",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "avg(gl_eudr_rma_ml_model_confidence{environment=\"$environment\"})", "legendFormat": "Model Confidence" }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 2,
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "orange", "value": 0.5 },
              { "color": "yellow", "value": 0.7 },
              { "color": "green", "value": 0.85 }
            ]
          },
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      },
      "options": {
        "showThresholdLabels": true,
        "showThresholdMarkers": true,
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "title": "ML Fallback Rate",
      "description": "Rate of ML model fallback to deterministic mode. High rate (>50%/hr) triggers warning alert.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "sum(rate(gl_eudr_rma_ml_fallback_total{environment=\"$environment\"}[5m])) * 3600", "legendFormat": "Fallback Rate (/hr)" },
        { "expr": "sum(rate(gl_eudr_rma_ml_fallback_total{environment=\"$environment\"}[5m])) / (sum(rate(gl_eudr_rma_strategies_recommended_total{environment=\"$environment\"}[5m])) > 0) * 100", "legendFormat": "Fallback %" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "drawStyle": "line",
            "lineInterpolation": "smooth"
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "title": "Remediation Plans",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 },
      "collapsed": false,
      "panels": []
    },
    {
      "title": "Active Remediation Plans",
      "description": "Current number of active remediation plans (draft, active, on_track, at_risk, delayed). Spike > 200% triggers info alert.",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "sum(gl_eudr_rma_active_plans{environment=\"$environment\"})", "legendFormat": "Active Plans" },
        { "expr": "sum(increase(gl_eudr_rma_plans_created_total{environment=\"$environment\"}[24h]))", "legendFormat": "New (24h)" }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "orange", "value": 100 },
              { "color": "red", "value": 200 }
            ]
          },
          "unit": "short"
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "title": "Plans Created Over Time",
      "description": "Rate of remediation plan creation segmented by plan template type.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 6, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "sum(rate(gl_eudr_rma_plans_created_total{environment=\"$environment\"}[5m])) * 3600", "legendFormat": "Total (/hr)" },
        { "expr": "sum by (template) (rate(gl_eudr_rma_plans_created_total{environment=\"$environment\"}[5m])) * 3600", "legendFormat": "{{template}} (/hr)" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "stacking": { "mode": "none" }
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "mean"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "title": "Plan Generation Latency (p50/p95/p99)",
      "description": "Latency for remediation plan generation (Engine 2). Target: p99 < 5 seconds.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(gl_eudr_rma_plan_generation_seconds_bucket{environment=\"$environment\"}[5m])) by (le))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum(rate(gl_eudr_rma_plan_generation_seconds_bucket{environment=\"$environment\"}[5m])) by (le))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum(rate(gl_eudr_rma_plan_generation_seconds_bucket{environment=\"$environment\"}[5m])) by (le))", "legendFormat": "p99" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 10, "drawStyle": "line", "lineInterpolation": "smooth" },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 2 }, { "color": "red", "value": 5 }] }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "title": "Milestone Completion Rate",
      "description": "Rate of milestone completion across all active remediation plans by plan phase.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 26 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "sum(rate(gl_eudr_rma_milestones_completed_total{environment=\"$environment\"}[5m])) * 86400", "legendFormat": "Total (/day)" },
        { "expr": "sum by (phase) (rate(gl_eudr_rma_milestones_completed_total{environment=\"$environment\"}[5m])) * 86400", "legendFormat": "{{phase}} (/day)" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 15, "drawStyle": "line", "lineInterpolation": "smooth", "stacking": { "mode": "normal" } }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "mean"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "title": "Capacity Building",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 34 },
      "collapsed": false,
      "panels": []
    },
    {
      "title": "Active Enrollments",
      "description": "Current number of active supplier capacity building enrollments across all programs.",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 35 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "sum(gl_eudr_rma_active_enrollments{environment=\"$environment\"})", "legendFormat": "Active Enrollments" }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 100 }, { "color": "orange", "value": 500 }] },
          "unit": "short"
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "title": "Enrollments by Commodity",
      "description": "Capacity building enrollments broken down by EUDR commodity (cattle, cocoa, coffee, oil_palm, rubber, soya, wood).",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 9, "x": 6, "y": 35 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "sum by (commodity) (increase(gl_eudr_rma_enrollments_total{environment=\"$environment\"}[30d]))", "legendFormat": "{{commodity}}" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "palette-classic" } }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" },
        "orientation": "horizontal",
        "barWidth": 0.7
      }
    },
    {
      "title": "Enrollments by Tier",
      "description": "Active capacity building enrollments by tier level (1=Awareness, 2=Basic, 3=Advanced, 4=Leadership).",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 9, "x": 15, "y": 35 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "sum by (tier) (increase(gl_eudr_rma_enrollments_total{environment=\"$environment\"}[30d]))", "legendFormat": "Tier {{tier}}" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "palette-classic" } }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" },
        "orientation": "vertical",
        "barWidth": 0.7,
        "stacking": "normal"
      }
    },
    {
      "title": "Effectiveness Tracking",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 43 },
      "collapsed": false,
      "panels": []
    },
    {
      "title": "Portfolio Risk Reduction Trend",
      "description": "Average composite risk reduction percentage across the mitigation portfolio over time. Target: >= 40% for active mitigation suppliers.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 44 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "avg(gl_eudr_rma_effectiveness_composite_reduction{environment=\"$environment\", commodity=~\"$commodity\", country=~\"$country\"}) or vector(0)", "legendFormat": "Avg Composite Reduction %" },
        { "expr": "max(gl_eudr_rma_effectiveness_composite_reduction{environment=\"$environment\"}) or vector(0)", "legendFormat": "Max Reduction %" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": { "lineWidth": 2, "fillOpacity": 20, "drawStyle": "line", "lineInterpolation": "smooth" },
          "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 20 }, { "color": "green", "value": 40 }] }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "title": "Portfolio ROI Trend",
      "description": "Average return on investment for mitigation activities. ROI = (Risk Reduction Value - Cost) / Cost * 100. Target: >= 300% (3:1 ratio).",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 44 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "avg(gl_eudr_rma_effectiveness_roi{environment=\"$environment\", commodity=~\"$commodity\", country=~\"$country\"}) or vector(0)", "legendFormat": "Avg ROI %" },
        { "expr": "max(gl_eudr_rma_effectiveness_roi{environment=\"$environment\"}) or vector(0)", "legendFormat": "Max ROI %" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": { "lineWidth": 2, "fillOpacity": 15, "drawStyle": "line", "lineInterpolation": "smooth" },
          "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 100 }, { "color": "green", "value": 300 }] }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "title": "Continuous Monitoring",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 52 },
      "collapsed": false,
      "panels": []
    },
    {
      "title": "Trigger Events by Severity",
      "description": "Rate of monitoring trigger events detected by source agent and severity. Critical events require acknowledgment within 4 hours.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 53 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "sum(rate(gl_eudr_rma_trigger_events_total{environment=\"$environment\", severity=\"critical\"}[5m])) * 3600", "legendFormat": "Critical (/hr)" },
        { "expr": "sum(rate(gl_eudr_rma_trigger_events_total{environment=\"$environment\", severity=\"high\"}[5m])) * 3600", "legendFormat": "High (/hr)" },
        { "expr": "sum(rate(gl_eudr_rma_trigger_events_total{environment=\"$environment\", severity=\"medium\"}[5m])) * 3600", "legendFormat": "Medium (/hr)" },
        { "expr": "sum(rate(gl_eudr_rma_trigger_events_total{environment=\"$environment\", severity=\"low\"}[5m])) * 3600", "legendFormat": "Low (/hr)" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 15, "drawStyle": "line", "lineInterpolation": "smooth", "stacking": { "mode": "none" } }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Critical (/hr)" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "High (/hr)" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Medium (/hr)" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Low (/hr)" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "title": "Unresolved Triggers",
      "description": "Count of unresolved trigger events by severity. Critical unresolved for > 4 hours triggers pager alert.",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 53 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "sum(gl_eudr_rma_unresolved_triggers{environment=\"$environment\"})", "legendFormat": "Total Unresolved" },
        { "expr": "sum(gl_eudr_rma_unresolved_triggers{environment=\"$environment\", severity=\"critical\"})", "legendFormat": "Critical" },
        { "expr": "sum(gl_eudr_rma_unresolved_triggers{environment=\"$environment\", severity=\"high\"})", "legendFormat": "High" }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 5 }, { "color": "orange", "value": 10 }, { "color": "red", "value": 20 }] },
          "unit": "short"
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "title": "Trigger Events by Source Agent",
      "description": "Distribution of trigger events by upstream source agent (EUDR-016 through EUDR-024).",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 53 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "sum by (source_agent) (increase(gl_eudr_rma_trigger_events_total{environment=\"$environment\"}[24h]))", "legendFormat": "{{source_agent}}" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "palette-classic" } }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["value"] },
        "tooltip": { "mode": "single" },
        "pieType": "donut",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "title": "Cost-Benefit Optimization",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 61 },
      "collapsed": false,
      "panels": []
    },
    {
      "title": "Budget Optimization Runs",
      "description": "Rate of cost-benefit optimization runs by solver status. Tracks Engine 7 usage.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 62 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
