      "collapsed": false,
      "panels": []
    },
    {
      "title": "Countries Assessed",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(gl_eudr_cre_countries_assessed_total)", "legendFormat": "Total" },
        { "expr": "sum(increase(gl_eudr_cre_countries_assessed_total[24h]))", "legendFormat": "24h" }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      }
    },
    {
      "title": "High Risk Countries",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(gl_eudr_cre_countries_by_risk_level{risk_level=\"high\"})", "legendFormat": "High" },
        { "expr": "sum(gl_eudr_cre_countries_by_risk_level{risk_level=\"standard\"})", "legendFormat": "Standard" },
        { "expr": "sum(gl_eudr_cre_countries_by_risk_level{risk_level=\"low\"})", "legendFormat": "Low" }
