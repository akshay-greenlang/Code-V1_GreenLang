{
  "annotations": { "list": [] },
  "description": "AGENT-EUDR-028: Risk Assessment Engine (RAE) -- Composite risk score computation from multi-dimensional factor inputs, Article 10(2) criteria evaluation, Article 29 country benchmarking, risk level classification (negligible/low/standard/elevated/high/critical), manual risk overrides with dual-approval audit trail, historical risk trend analysis via TimescaleDB, DDS-ready report generation, and simplified due diligence eligibility determination for EUDR Articles 8, 10, 13, 29, 31 compliance",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "Overview",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "title": "Assessments Completed Rate",
      "description": "Rate of risk assessments completed over time by commodity. Tracks overall RAE throughput.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "sum(rate(gl_eudr_rae_assessments_total{environment=\"$environment\", commodity=~\"$commodity\"}[5m])) * 3600", "legendFormat": "Total (/hr)" },
        { "expr": "sum by (commodity) (rate(gl_eudr_rae_assessments_total{environment=\"$environment\", commodity=~\"$commodity\"}[5m])) * 3600", "legendFormat": "{{commodity}} (/hr)" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "drawStyle": "line",
            "pointSize": 5,
            "stacking": { "mode": "none" },
            "spanNulls": false,
            "lineInterpolation": "smooth"
          }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Total (/hr)" }, "properties": [{ "id": "color", "value": { "fixedColor": "white", "mode": "fixed" } }, { "id": "custom.lineWidth", "value": 3 }, { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 5] } }] }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "title": "Active Assessments",
      "description": "Current number of active risk assessments in progress. Spike > 200% triggers info alert.",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "sum(gl_eudr_rae_active_assessments{environment=\"$environment\"})", "legendFormat": "Active Assessments" },
        { "expr": "sum(increase(gl_eudr_rae_assessments_total{environment=\"$environment\"}[24h]))", "legendFormat": "Completed (24h)" }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "orange", "value": 100 },
              { "color": "red", "value": 200 }
            ]
          },
          "unit": "short"
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "title": "High Risk Operators",
      "description": "Current count of operators classified as high or critical risk. Persistent count > 20 triggers warning alert.",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "sum(gl_eudr_rae_high_risk_operators{environment=\"$environment\"})", "legendFormat": "High/Critical Operators" },
        { "expr": "sum(gl_eudr_rae_high_risk_operators{environment=\"$environment\", risk_level=\"critical\"})", "legendFormat": "Critical Only" }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "orange", "value": 10 },
              { "color": "red", "value": 20 }
            ]
          },
          "unit": "short"
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "title": "Assessment Duration (p50/p95/p99)",
      "description": "End-to-end risk assessment latency by percentile. Target: p99 < 5 seconds.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(gl_eudr_rae_assessment_duration_seconds_bucket{environment=\"$environment\"}[5m])) by (le))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum(rate(gl_eudr_rae_assessment_duration_seconds_bucket{environment=\"$environment\"}[5m])) by (le))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum(rate(gl_eudr_rae_assessment_duration_seconds_bucket{environment=\"$environment\"}[5m])) by (le))", "legendFormat": "p99" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "thresholdsStyle": { "mode": "line" }
          },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 2 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "title": "API Errors Rate",
      "description": "Rate of API errors by error type. Sustained rate > 1% triggers critical alert.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "sum(rate(gl_eudr_rae_api_errors_total{environment=\"$environment\"}[5m])) * 3600", "legendFormat": "Total Errors (/hr)" },
        { "expr": "sum by (error_type) (rate(gl_eudr_rae_api_errors_total{environment=\"$environment\"}[5m])) * 3600", "legendFormat": "{{error_type}} (/hr)" },
        { "expr": "sum(rate(gl_eudr_rae_api_errors_total{environment=\"$environment\"}[5m])) / (sum(rate(gl_eudr_rae_assessments_total{environment=\"$environment\"}[5m])) > 0) * 100", "legendFormat": "Error Rate %" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "drawStyle": "line",
            "lineInterpolation": "smooth"
          }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Error Rate %" }, "properties": [{ "id": "custom.lineWidth", "value": 3 }, { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "title": "Risk Scores",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 },
      "collapsed": false,
      "panels": []
    },
    {
      "title": "Average Risk Score",
      "description": "Current average composite risk score across all recent assessments. Target: maintain below 0.50 (standard threshold).",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "avg(gl_eudr_rae_average_risk_score{environment=\"$environment\", commodity=~\"$commodity\"})", "legendFormat": "Avg Risk Score" }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 4,
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 0.25 },
              { "color": "orange", "value": 0.50 },
              { "color": "red", "value": 0.70 }
            ]
          },
          "unit": "none",
          "min": 0,
          "max": 1
        }
      },
      "options": {
        "showThresholdLabels": true,
        "showThresholdMarkers": true,
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "title": "Factor Aggregations Rate",
      "description": "Rate of multi-dimensional factor aggregations computed. Each aggregation combines inputs from upstream risk agents (EUDR-016 through EUDR-025).",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 9, "x": 6, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "sum(rate(gl_eudr_rae_factor_aggregations_total{environment=\"$environment\"}[5m])) * 3600", "legendFormat": "Total (/hr)" },
        { "expr": "sum by (dimension) (rate(gl_eudr_rae_factor_aggregations_total{environment=\"$environment\"}[5m])) * 3600", "legendFormat": "{{dimension}} (/hr)" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "stacking": { "mode": "none" }
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "mean"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "title": "Aggregation Duration (p50/p95/p99)",
      "description": "Factor aggregation computation latency by percentile. Target: p99 < 2 seconds.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 9, "x": 15, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(gl_eudr_rae_aggregation_duration_seconds_bucket{environment=\"$environment\"}[5m])) by (le))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum(rate(gl_eudr_rae_aggregation_duration_seconds_bucket{environment=\"$environment\"}[5m])) by (le))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum(rate(gl_eudr_rae_aggregation_duration_seconds_bucket{environment=\"$environment\"}[5m])) by (le))", "legendFormat": "p99" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 10, "drawStyle": "line", "lineInterpolation": "smooth", "thresholdsStyle": { "mode": "line" } },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 2 }] }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "title": "Risk Level Classification Distribution",
      "description": "Distribution of risk classifications (negligible, low, standard, elevated, high, critical) over the last 24 hours.",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 26 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "sum by (risk_level) (increase(gl_eudr_rae_classifications_total{environment=\"$environment\", risk_level=~\"$risk_level\"}[24h]))", "legendFormat": "{{risk_level}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["value"] },
        "tooltip": { "mode": "single" },
        "pieType": "donut",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "title": "Classification Duration (p50/p95/p99)",
      "description": "Risk classification computation latency. Target: p99 < 500ms.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 9, "x": 6, "y": 26 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(gl_eudr_rae_classification_duration_seconds_bucket{environment=\"$environment\"}[5m])) by (le))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum(rate(gl_eudr_rae_classification_duration_seconds_bucket{environment=\"$environment\"}[5m])) by (le))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum(rate(gl_eudr_rae_classification_duration_seconds_bucket{environment=\"$environment\"}[5m])) by (le))", "legendFormat": "p99" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 10, "drawStyle": "line", "lineInterpolation": "smooth" },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.2 }, { "color": "red", "value": 0.5 }] }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "title": "Benchmarks Applied & Override Count",
      "description": "Article 29 country benchmarks applied and manual risk overrides in effect. High override count may indicate data quality issues.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 9, "x": 15, "y": 26 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "sum(rate(gl_eudr_rae_benchmarks_applied_total{environment=\"$environment\"}[5m])) * 3600", "legendFormat": "Benchmarks Applied (/hr)" },
        { "expr": "sum(gl_eudr_rae_override_count{environment=\"$environment\"})", "legendFormat": "Active Overrides" },
        { "expr": "sum(rate(gl_eudr_rae_overrides_applied_total{environment=\"$environment\"}[5m])) * 3600", "legendFormat": "New Overrides (/hr)" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "stacking": { "mode": "none" }
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "title": "Article 10 Criteria",
