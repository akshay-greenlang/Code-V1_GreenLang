        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "mean"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "title": "Criteria Evaluation Latency (p50/p95/p99)",
      "description": "Article 10(2) criteria evaluation latency by percentile. Target: p99 < 1 second per criterion.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 35 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(gl_eudr_rae_criteria_evaluation_duration_seconds_bucket{environment=\"$environment\"}[5m])) by (le))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum(rate(gl_eudr_rae_criteria_evaluation_duration_seconds_bucket{environment=\"$environment\"}[5m])) by (le))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum(rate(gl_eudr_rae_criteria_evaluation_duration_seconds_bucket{environment=\"$environment\"}[5m])) by (le))", "legendFormat": "p99" }
      ],
      "fieldConfig": {
        "defaults": {
