      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(gl_eudr_pbm_boundaries_created_total[5m]) * 60",
          "legendFormat": "Created"
        },
        {
          "expr": "rate(gl_eudr_pbm_boundaries_updated_total[5m]) * 60",
          "legendFormat": "Updated"
        }
      ]
