{
  "annotations": { "list": [] },
  "description": "AGENT-EUDR-030: Documentation Generator (DGN) -- DDS generation per Article 4, Article 9 information package assembly, risk assessment documentation, mitigation documentation, compliance package building, EU Information System submission tracking, document validation, version control, and audit-ready documentation for EUDR Articles 4, 9, 10, 11, 12, 14-16, 29, 31 compliance",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "Document Generation Operations",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 1,
      "title": "DDS Generated",
      "description": "Rate of Due Diligence Statement documents generated over time by commodity. Each DDS represents a complete Article 4 compliance filing linking Article 9 data, risk assessment, and mitigation documentation.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "sum(rate(gl_eudr_dgn_dds_generated_total{environment=\"$environment\"}[5m])) * 3600", "legendFormat": "Total (/hr)", "refId": "A" },
        { "expr": "sum by (commodity) (rate(gl_eudr_dgn_dds_generated_total{environment=\"$environment\", commodity=~\"$commodity\"}[5m])) * 3600", "legendFormat": "{{commodity}} (/hr)", "refId": "B" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "drawStyle": "line",
            "pointSize": 5,
            "stacking": { "mode": "none" },
            "spanNulls": false,
            "lineInterpolation": "smooth"
          }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Total (/hr)" }, "properties": [{ "id": "color", "value": { "fixedColor": "white", "mode": "fixed" } }, { "id": "custom.lineWidth", "value": 3 }, { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 5] } }] }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 2,
      "title": "Article 9 Assemblies",
      "description": "Rate of Article 9 information packages assembled over time by commodity. Each package collects all required data elements (geolocation, suppliers, products, production dates, certifications) per Article 9.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "sum(rate(gl_eudr_dgn_article9_assembled_total{environment=\"$environment\"}[5m])) * 3600", "legendFormat": "Total (/hr)", "refId": "A" },
        { "expr": "sum by (commodity) (rate(gl_eudr_dgn_article9_assembled_total{environment=\"$environment\", commodity=~\"$commodity\"}[5m])) * 3600", "legendFormat": "{{commodity}} (/hr)", "refId": "B" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "drawStyle": "line",
            "pointSize": 5,
            "stacking": { "mode": "none" },
            "spanNulls": false,
            "lineInterpolation": "smooth"
          }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Total (/hr)" }, "properties": [{ "id": "color", "value": { "fixedColor": "white", "mode": "fixed" } }, { "id": "custom.lineWidth", "value": 3 }, { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 5] } }] }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 3,
      "title": "Risk Docs Generated",
      "description": "Rate of risk assessment documents generated over time. Each document captures composite scores, criterion evaluations, country benchmarking, and dimension breakdowns for Articles 10, 29.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "sum(rate(gl_eudr_dgn_risk_docs_generated_total{environment=\"$environment\"}[5m])) * 3600", "legendFormat": "Total (/hr)", "refId": "A" },
        { "expr": "sum by (risk_level) (rate(gl_eudr_dgn_risk_docs_generated_total{environment=\"$environment\"}[5m])) * 3600", "legendFormat": "{{risk_level}} (/hr)", "refId": "B" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "stacking": { "mode": "none" }
          }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Total (/hr)" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }, { "id": "custom.lineWidth", "value": 3 }] }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 4,
      "title": "Mitigation Docs Generated",
      "description": "Rate of mitigation documentation generated over time. Each document captures pre/post risk scores, Article 11 measure summaries, and verification outcomes.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "sum(rate(gl_eudr_dgn_mitigation_docs_generated_total{environment=\"$environment\"}[5m])) * 3600", "legendFormat": "Total (/hr)", "refId": "A" },
        { "expr": "sum by (verification_result) (rate(gl_eudr_dgn_mitigation_docs_generated_total{environment=\"$environment\"}[5m])) * 3600", "legendFormat": "{{verification_result}} (/hr)", "refId": "B" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "stacking": { "mode": "none" }
          }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Total (/hr)" }, "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }, { "id": "custom.lineWidth", "value": 3 }] }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "title": "Packages, Submissions & Validations",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 5,
      "title": "Compliance Packages Built",
      "description": "Rate of complete compliance packages built over time by commodity. Each package assembles DDS, Article 9 data, risk assessment, mitigation, and supporting evidence for authority review.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "sum(rate(gl_eudr_dgn_packages_built_total{environment=\"$environment\"}[5m])) * 3600", "legendFormat": "Total (/hr)", "refId": "A" },
        { "expr": "sum by (commodity) (rate(gl_eudr_dgn_packages_built_total{environment=\"$environment\", commodity=~\"$commodity\"}[5m])) * 3600", "legendFormat": "{{commodity}} (/hr)", "refId": "B" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "stacking": { "mode": "none" }
          }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Total (/hr)" }, "properties": [{ "id": "custom.lineWidth", "value": 3 }, { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 5] } }] }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "mean"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 6,
      "title": "Submissions by Status",
      "description": "Rate of EU Information System submissions stacked by status. Tracks the full submission lifecycle: pending, submitted, acknowledged, rejected, resubmitted.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "sum by (status) (rate(gl_eudr_dgn_submissions_total{environment=\"$environment\"}[5m])) * 3600", "legendFormat": "{{status}} (/hr)", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20,
            "drawStyle": "line",
            "pointSize": 5,
            "stacking": { "mode": "normal" },
            "spanNulls": false,
            "lineInterpolation": "smooth"
          },
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "mean"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 7,
      "title": "Validations by Result",
      "description": "Distribution of document validation results in the last 24 hours. Valid means zero blocking errors; invalid indicates blocking errors that must be resolved before submission.",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "sum(increase(gl_eudr_dgn_validations_total{environment=\"$environment\", result=\"valid\"}[24h]))", "legendFormat": "Valid", "refId": "A" },
        { "expr": "sum(increase(gl_eudr_dgn_validations_total{environment=\"$environment\", result=\"invalid\"}[24h]))", "legendFormat": "Invalid", "refId": "B" },
        { "expr": "sum(increase(gl_eudr_dgn_validations_total{environment=\"$environment\", result=\"warnings_only\"}[24h]))", "legendFormat": "Warnings Only", "refId": "C" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Valid" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Invalid" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Warnings Only" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["value"] },
        "tooltip": { "mode": "single" },
        "pieType": "donut",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "id": 8,
      "title": "API Errors",
      "description": "Rate of API errors (4xx and 5xx) across all /v1/eudr-dgn endpoints. Sustained 5xx error rate > 1% triggers critical alert.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 26 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "sum(rate(gl_eudr_dgn_api_errors_total{environment=\"$environment\", status_code=~\"5..\"}[5m])) * 3600", "legendFormat": "5xx Errors (/hr)", "refId": "A" },
        { "expr": "sum(rate(gl_eudr_dgn_api_errors_total{environment=\"$environment\", status_code=~\"4..\"}[5m])) * 3600", "legendFormat": "4xx Errors (/hr)", "refId": "B" },
        { "expr": "sum(rate(gl_eudr_dgn_api_errors_total{environment=\"$environment\"}[5m])) / (sum(rate(gl_eudr_dgn_api_requests_total{environment=\"$environment\"}[5m])) > 0) * 100", "legendFormat": "Error Rate %", "refId": "C" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "stacking": { "mode": "none" }
          }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "5xx Errors (/hr)" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "4xx Errors (/hr)" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Error Rate %" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }, { "id": "custom.axisPlacement", "value": "right" }, { "id": "unit", "value": "percent" }] }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "title": "Latency Metrics",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 34 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 9,
      "title": "DDS Generation Latency (p50/p95/p99)",
      "description": "Latency percentiles for end-to-end DDS document generation. Includes Article 9 data assembly, risk/mitigation document linking, content structuring, and schema validation. Target: p99 < 5 seconds.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 35 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(gl_eudr_dgn_dds_generation_seconds_bucket{environment=\"$environment\"}[5m])) by (le))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum(rate(gl_eudr_dgn_dds_generation_seconds_bucket{environment=\"$environment\"}[5m])) by (le))", "legendFormat": "p95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum(rate(gl_eudr_dgn_dds_generation_seconds_bucket{environment=\"$environment\"}[5m])) by (le))", "legendFormat": "p99", "refId": "C" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "thresholdsStyle": { "mode": "line" }
          },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 2 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 10,
      "title": "Article 9 Assembly Latency (p50/p95/p99)",
      "description": "Latency percentiles for Article 9 information package assembly including geolocation collection, supplier data aggregation, product mapping, and completeness scoring. Target: p99 < 3 seconds.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 35 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(gl_eudr_dgn_article9_assembly_seconds_bucket{environment=\"$environment\"}[5m])) by (le))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum(rate(gl_eudr_dgn_article9_assembly_seconds_bucket{environment=\"$environment\"}[5m])) by (le))", "legendFormat": "p95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum(rate(gl_eudr_dgn_article9_assembly_seconds_bucket{environment=\"$environment\"}[5m])) by (le))", "legendFormat": "p99", "refId": "C" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "thresholdsStyle": { "mode": "line" }
          },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1.5 },
              { "color": "red", "value": 3 }
            ]
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 11,
      "title": "Package Build Latency (p50/p95/p99)",
      "description": "Latency percentiles for compliance package building including section assembly, table-of-contents generation, cross-reference mapping, and integrity hashing. Target: p99 < 8 seconds.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 43 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(gl_eudr_dgn_package_build_seconds_bucket{environment=\"$environment\"}[5m])) by (le))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum(rate(gl_eudr_dgn_package_build_seconds_bucket{environment=\"$environment\"}[5m])) by (le))", "legendFormat": "p95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum(rate(gl_eudr_dgn_package_build_seconds_bucket{environment=\"$environment\"}[5m])) by (le))", "legendFormat": "p99", "refId": "C" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "thresholdsStyle": { "mode": "line" }
          },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 4 },
              { "color": "red", "value": 8 }
            ]
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 12,
      "title": "Submission Latency (p50/p95/p99)",
      "description": "Latency percentiles for EU Information System submission including payload preparation, schema validation, transmission, and acknowledgement receipt. Target: p99 < 15 seconds.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 43 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(gl_eudr_dgn_submission_seconds_bucket{environment=\"$environment\"}[5m])) by (le))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum(rate(gl_eudr_dgn_submission_seconds_bucket{environment=\"$environment\"}[5m])) by (le))", "legendFormat": "p95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum(rate(gl_eudr_dgn_submission_seconds_bucket{environment=\"$environment\"}[5m])) by (le))", "legendFormat": "p99", "refId": "C" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "thresholdsStyle": { "mode": "line" }
          },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 8 },
              { "color": "red", "value": 15 }
            ]
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
