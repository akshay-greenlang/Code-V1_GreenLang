    {
      "title": "Operational Gauges",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 51 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 13,
      "title": "Active Drafts",
      "description": "Current number of DDS documents in draft status. These are generated but not yet submitted to the EU Information System. Spike > 200% baseline triggers info alert.",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 52 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "sum(gl_eudr_dgn_active_drafts{environment=\"$environment\"})", "legendFormat": "Active Drafts", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "orange", "value": 100 },
              { "color": "red", "value": 200 }
            ]
          },
          "unit": "short"
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "id": 14,
      "title": "Pending Submissions",
      "description": "Current number of DDS submissions in pending or submitted status awaiting EU IS acknowledgement. High count (> 20) may indicate connectivity issues or EU IS delays.",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 52 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "sum(gl_eudr_dgn_pending_submissions{environment=\"$environment\"})", "legendFormat": "Pending Submissions", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "orange", "value": 20 },
              { "color": "red", "value": 50 }
            ]
          },
          "unit": "short"
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "id": 15,
      "title": "Rejected Submissions",
      "description": "Current number of DDS submissions rejected by EU IS requiring amendment and resubmission. Non-zero triggers warning alert. > 10 triggers critical.",
      "type": "stat",
