        { "expr": "gl_eudr_cm_deforestation_confirmed_total", "legendFormat": "Confirmed Events" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 0.8 }
            ]
          },
          "custom": {
            "align": "auto",
            "filterable": true
          }
        },
        "overrides": [
