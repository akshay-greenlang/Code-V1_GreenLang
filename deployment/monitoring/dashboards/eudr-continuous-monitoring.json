              {
                "id": "custom.cellOptions",
                "value": { "type": "color-text" }
              },
              {
                "id": "mappings",
                "value": [
                  {
                    "options": {
                      "critical": { "color": "red", "text": "CRITICAL" },
                      "high": { "color": "orange", "text": "HIGH" },
                      "medium": { "color": "yellow", "text": "MEDIUM" }
                    },
                    "type": "value"
                  }
                ]
              }
            ]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 23 },
      "id": 20,
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "risk_score", "desc": true }],
        "footer": { "show": true, "reducer": ["count"] }
      },
      "title": "High-Risk Plots",
      "type": "table",
      "targets": [
        { "expr": "gl_eudr_cm_high_risk_plot_info", "legendFormat": "{{plot_id}} - {{country}} - {{risk_level}} - {{risk_score}}", "format": "table", "instant": true }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 31 },
      "id": 21,
      "title": "Compliance Status",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "percentunit",
          "min": 0,
