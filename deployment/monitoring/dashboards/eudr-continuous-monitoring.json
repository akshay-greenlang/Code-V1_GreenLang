{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "AGENT-EUDR-033 Continuous Monitoring Agent - Active Jobs, Alerts, Supply Chain Surveillance, Deforestation Detection, Compliance Tracking, Data Freshness, Risk Monitoring & System Performance",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "Monitoring Health",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "green", "value": 20 }
            ]
          }
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 1 },
      "id": 2,
      "options": {
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "title": "Active Monitoring Jobs",
      "type": "gauge",
      "targets": [
        { "expr": "gl_eudr_cm_active_monitoring_jobs", "legendFormat": "Active Jobs" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            {
              "options": {
                "0": { "text": "FAILED", "color": "red" },
                "1": { "text": "SUCCESS", "color": "green" },
                "2": { "text": "PARTIAL", "color": "yellow" },
                "3": { "text": "RUNNING", "color": "blue" }
              },
              "type": "value"
            }
          ]
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 1 },
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "title": "Last Run Status",
      "type": "stat",
      "targets": [
        { "expr": "gl_eudr_cm_last_run_status", "legendFormat": "Status" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short"
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 1 },
      "id": 4,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "pieType": "donut",
        "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] },
        "tooltip": { "mode": "single" }
      },
      "title": "Jobs by Type",
      "type": "piechart",
      "targets": [
        { "expr": "sum by (job_type) (gl_eudr_cm_jobs_by_type)", "legendFormat": "{{job_type}}" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.5 },
              { "color": "yellow", "value": 0.75 },
              { "color": "green", "value": 0.9 }
            ]
          }
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 1 },
      "id": 5,
      "options": {
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "title": "Monitoring Coverage %",
      "type": "gauge",
      "targets": [
        { "expr": "gl_eudr_cm_monitoring_coverage_ratio", "legendFormat": "Coverage" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 },
      "id": 6,
      "title": "Alert Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 200 }
            ]
          }
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 8 },
      "id": 7,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "title": "Total Alerts",
      "type": "stat",
      "targets": [
        { "expr": "sum(gl_eudr_cm_alerts_total)", "legendFormat": "Total" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "bars", "fillOpacity": 80, "stacking": { "mode": "normal" } },
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "critical" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "high" },
            "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "medium" },
            "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "low" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          }
        ]
      },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 8 },
      "id": 8,
      "options": {
        "legend": { "displayMode": "table", "calcs": ["sum"] },
        "tooltip": { "mode": "multi" }
      },
      "title": "Alerts by Severity",
      "type": "timeseries",
      "targets": [
        { "expr": "sum by (severity) (gl_eudr_cm_alerts_by_severity)", "legendFormat": "{{severity}}" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "fillOpacity": 20, "pointSize": 5 },
          "color": { "mode": "palette-classic" }
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 8 },
      "id": 9,
      "options": {
        "legend": { "displayMode": "table", "calcs": ["sum", "last"] },
        "tooltip": { "mode": "multi" }
      },
      "title": "Alert Trend",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(rate(gl_eudr_cm_alerts_fired_total[5m]))", "legendFormat": "Fired" },
        { "expr": "sum(rate(gl_eudr_cm_alerts_resolved_total[5m]))", "legendFormat": "Resolved" },
        { "expr": "sum(rate(gl_eudr_cm_alerts_acknowledged_total[5m]))", "legendFormat": "Acknowledged" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          },
          "custom": {
            "align": "auto",
            "filterable": true
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "severity" },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-text"
                }
              },
              {
                "id": "mappings",
                "value": [
                  {
                    "options": {
                      "critical": { "color": "red", "text": "CRITICAL" },
                      "high": { "color": "orange", "text": "HIGH" },
                      "medium": { "color": "yellow", "text": "MEDIUM" },
                      "low": { "color": "green", "text": "LOW" }
                    },
                    "type": "value"
                  }
                ]
              }
            ]
          }
        ]
      },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 8 },
      "id": 10,
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "severity", "desc": true }],
        "footer": { "show": true, "reducer": ["count"] }
      },
      "title": "Unresolved Alerts",
      "type": "table",
      "targets": [
        { "expr": "gl_eudr_cm_unresolved_alerts_info", "legendFormat": "{{alert_id}} - {{alert_type}} - {{severity}} - {{entity_id}}", "format": "table", "instant": true }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 11,
      "title": "Supply Chain Monitoring",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "green", "value": 100 }
            ]
          }
        }
      },
      "gridPos": { "h": 7, "w": 6, "x": 0, "y": 15 },
      "id": 12,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "title": "Suppliers Scanned",
      "type": "stat",
      "targets": [
        { "expr": "sum(gl_eudr_cm_suppliers_scanned_total)", "legendFormat": "Total Scanned" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "custom": {
            "align": "auto",
            "filterable": true
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "days_until_expiry" },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": { "type": "color-background" }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "red", "value": null },
                    { "color": "orange", "value": 14 },
                    { "color": "yellow", "value": 30 },
                    { "color": "green", "value": 90 }
                  ]
                }
              }
            ]
          }
        ]
      },
      "gridPos": { "h": 7, "w": 6, "x": 6, "y": 15 },
      "id": 13,
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "days_until_expiry", "desc": false }],
        "footer": { "show": true, "reducer": ["count"] }
      },
      "title": "Certification Expiry Alerts",
      "type": "table",
      "targets": [
        { "expr": "gl_eudr_cm_certification_expiry_days", "legendFormat": "{{supplier_id}} - {{cert_type}} - {{days_until_expiry}}", "format": "table", "instant": true }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "fillOpacity": 20, "pointSize": 5 },
          "color": { "mode": "palette-classic" }
        }
      },
      "gridPos": { "h": 7, "w": 6, "x": 12, "y": 15 },
      "id": 14,
      "options": {
        "legend": { "displayMode": "table", "calcs": ["sum", "last"] },
        "tooltip": { "mode": "multi" }
      },
      "title": "Geolocation Changes Detected",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(rate(gl_eudr_cm_geolocation_changes_total[5m]))", "legendFormat": "Changes/s" },
        { "expr": "sum(rate(gl_eudr_cm_geolocation_anomalies_total[5m]))", "legendFormat": "Anomalies/s" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "scaleDistribution": { "type": "linear" }
          },
          "color": {
            "mode": "scheme",
            "schemeType": "sequential",
            "schemeName": "RdYlGn",
            "reverse": true
          }
        }
      },
      "gridPos": { "h": 7, "w": 6, "x": 18, "y": 15 },
      "id": 15,
      "options": {
        "calculate": true,
        "calculation": { "xBuckets": { "mode": "size", "value": "1h" } },
        "cellGap": 1,
        "color": {
          "mode": "scheme",
          "schemeType": "sequential",
          "schemeName": "RdYlGn",
          "reverse": true,
          "fill": "dark-orange",
          "exponent": 0.5
        },
        "yAxis": { "axisPlacement": "left" },
        "tooltip": { "show": true }
      },
      "title": "Supplier Status Changes",
      "type": "heatmap",
      "targets": [
        { "expr": "sum by (le) (rate(gl_eudr_cm_supplier_status_change_bucket[5m]))", "legendFormat": "{{le}}", "format": "heatmap" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "id": 16,
      "title": "Deforestation Monitoring",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "orange", "value": 15 },
              { "color": "red", "value": 30 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 23 },
      "id": 17,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "title": "Deforestation Alerts",
      "type": "stat",
      "targets": [
        { "expr": "gl_eudr_cm_deforestation_alerts_active", "legendFormat": "Active Alerts" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.3 },
              { "color": "red", "value": 0.7 }
            ]
          },
          "custom": {
            "hideFrom": { "legend": false, "tooltip": false, "viz": false }
          }
        }
      },
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 23 },
      "id": 18,
      "options": {
        "basemap": {
          "config": {},
          "name": "Layer 0",
          "type": "default"
        },
        "controls": {
          "mouseWheelZoom": true,
          "showAttribution": true,
          "showDebug": false,
          "showMeasure": false,
          "showZoom": true
        },
        "layers": [
          {
            "config": {
              "showLegend": true,
              "style": {
                "color": { "field": "risk_score", "fixed": "dark-red" },
                "opacity": 0.7,
                "rotation": { "fixed": 0, "max": 360, "min": -360, "mode": "mod" },
                "size": { "field": "severity_value", "fixed": 5, "max": 15, "min": 2 },
                "symbol": { "fixed": "img/icons/marker/circle.svg", "mode": "fixed" },
                "text": { "field": "location_name", "fixed": "", "mode": "field" },
                "textConfig": { "fontSize": 10, "offsetX": 0, "offsetY": 0, "textAlign": "center", "textBaseline": "top" }
              }
            },
            "location": {
              "latitude": "latitude",
              "longitude": "longitude",
              "mode": "coords"
            },
            "name": "Deforestation Alerts",
            "type": "markers"
          }
        ],
        "tooltip": { "mode": "details" },
        "view": {
          "allLayers": true,
          "id": "zero",
          "lat": 0,
          "lon": 0,
          "zoom": 2
        }
      },
      "title": "Alert Locations",
      "type": "geomap",
      "targets": [
        { "expr": "gl_eudr_cm_deforestation_alert_location", "legendFormat": "{{location_name}}", "format": "table", "instant": true }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "fillOpacity": 15, "lineWidth": 2, "pointSize": 5 },
          "color": { "mode": "palette-classic" }
        }
      },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 23 },
      "id": 19,
      "options": {
        "legend": { "displayMode": "table", "calcs": ["mean", "max", "last"] },
        "tooltip": { "mode": "multi" }
      },
      "title": "Forest Loss Correlation",
      "type": "timeseries",
      "targets": [
        { "expr": "gl_eudr_cm_forest_loss_area_hectares", "legendFormat": "Forest Loss (ha)" },
