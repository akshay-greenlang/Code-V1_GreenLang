      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(gl_eudr_sat_analysis_duration_seconds_bucket[5m]))",
          "legendFormat": "p99 - {{operation}}"
        },
        {
          "expr": "histogram_quantile(0.95, rate(gl_eudr_sat_analysis_duration_seconds_bucket[5m]))",
          "legendFormat": "p95 - {{operation}}"
        },
        {
          "expr": "histogram_quantile(0.50, rate(gl_eudr_sat_analysis_duration_seconds_bucket[5m]))",
          "legendFormat": "p50 - {{operation}}"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 24 },
