  },
  "description": "AGENT-EUDR-003: Satellite Monitoring Agent - Monitoring Dashboard",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "green", "value": 80 }
            ]
          }
        }
      },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 1 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Avg Detection Confidence",
      "type": "stat",
      "targets": [
        {
          "expr": "gl_eudr_sat_avg_detection_confidence",
          "legendFormat": "Confidence"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 1 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Active Monitoring Plots",
      "type": "stat",
      "targets": [
        {
          "expr": "gl_eudr_sat_active_monitoring_plots",
          "legendFormat": "Active Plots"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 1 },
      "id": 4,
      "title": "Baselines Established (24h)",
      "type": "stat",
      "targets": [
        {
          "expr": "increase(gl_eudr_sat_baselines_established_total[24h])",
          "legendFormat": "Baselines"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        }
      },
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 1 },
      "id": 5,
      "title": "Deforestation Detected (24h)",
      "type": "stat",
      "targets": [
        {
          "expr": "increase(gl_eudr_sat_deforestation_detected_total[24h])",
          "legendFormat": "Deforestation"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 6 },
      "id": 10,
      "title": "Imagery Acquisition",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 7 },
      "id": 11,
      "title": "Scenes Queried (per minute)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(gl_eudr_sat_scenes_queried_total[5m]) * 60",
          "legendFormat": "{{source}} - {{status}}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 7 },
      "id": 12,
      "title": "Scenes Downloaded & Data Volume",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(gl_eudr_sat_scenes_downloaded_total[5m]) * 60",
          "legendFormat": "Downloads/min - {{source}}"
        },
        {
          "expr": "rate(gl_eudr_sat_imagery_download_bytes_total[5m])",
          "legendFormat": "Bytes/sec - {{source}}"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 15 },
      "id": 20,
      "title": "Analysis Pipeline",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "id": 21,
      "title": "Analysis Operations (per minute)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(gl_eudr_sat_ndvi_calculations_total[5m]) * 60",
          "legendFormat": "NDVI Calcs - {{index_type}}"
        },
        {
          "expr": "rate(gl_eudr_sat_change_detections_total[5m]) * 60",
          "legendFormat": "Change Detect - {{method}}"
        },
        {
          "expr": "rate(gl_eudr_sat_fusion_analyses_total[5m]) * 60",
          "legendFormat": "Fusion - {{sources_count}} sources"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
