{
  "annotations": { "list": [] },
  "description": "AGENT-EUDR-021: Indigenous Rights Checker Agent -- territory registration and management, Free Prior and Informed Consent (FPIC) verification, supply chain overlap detection, community consultation tracking, rights violation monitoring, compliance scoring, document authentication, API gateway metrics, and EUDR indigenous rights compliance reporting",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "Overview",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "title": "Active Territories",
      "description": "Total number of indigenous territories currently registered and actively monitored in the system",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "sum(gl_eudr_irc_active_territories{environment=\"$environment\"})", "legendFormat": "Active Territories" },
        { "expr": "sum(increase(gl_eudr_irc_territories_registered_total{environment=\"$environment\"}[24h]))", "legendFormat": "Registered (24h)" },
        { "expr": "sum(gl_eudr_irc_active_territories{environment=\"$environment\", status=\"verified\"})", "legendFormat": "Verified" },
        { "expr": "sum(gl_eudr_irc_active_territories{environment=\"$environment\", status=\"pending_review\"})", "legendFormat": "Pending Review" }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 10 },
              { "color": "yellow", "value": 50 },
              { "color": "green", "value": 100 }
            ]
          },
          "unit": "short"
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "title": "Communities Registered",
      "description": "Total indigenous communities registered across all monitored regions",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "sum(gl_eudr_irc_communities_registered_total{environment=\"$environment\"})", "legendFormat": "Total Communities" },
        { "expr": "sum(increase(gl_eudr_irc_communities_registered_total{environment=\"$environment\"}[24h]))", "legendFormat": "New (24h)" },
        { "expr": "sum(gl_eudr_irc_communities_registered_total{environment=\"$environment\"}) by (country)", "legendFormat": "{{country}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 25 },
              { "color": "yellow", "value": 100 },
              { "color": "green", "value": 250 }
            ]
          },
          "unit": "short"
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "title": "Unresolved Violations",
      "description": "Current count of unresolved indigenous rights violations requiring attention. Alert fires when count exceeds 20.",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "sum(gl_eudr_irc_unresolved_violations{environment=\"$environment\"})", "legendFormat": "Unresolved" },
        { "expr": "sum(gl_eudr_irc_unresolved_violations{environment=\"$environment\", severity=\"critical\"})", "legendFormat": "Critical" },
        { "expr": "sum(gl_eudr_irc_unresolved_violations{environment=\"$environment\", severity=\"high\"})", "legendFormat": "High" },
        { "expr": "sum(increase(gl_eudr_irc_violations_detected_total{environment=\"$environment\"}[1h]))", "legendFormat": "New (1h)" }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "orange", "value": 10 },
              { "color": "red", "value": 20 }
            ]
          },
          "unit": "short"
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "title": "Compliance Score",
      "description": "Average indigenous rights compliance score across all assessed supply chains. Thresholds: <60 red, 60-80 yellow, >80 green.",
      "type": "gauge",
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "avg(gl_eudr_irc_compliance_score_avg{environment=\"$environment\"})", "legendFormat": "Avg Compliance Score" }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 1,
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "orange", "value": 40 },
              { "color": "yellow", "value": 60 },
              { "color": "green", "value": 80 }
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      },
      "options": {
        "showThresholdLabels": true,
        "showThresholdMarkers": true,
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "title": "Activity Metrics",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 6 },
      "collapsed": false,
      "panels": []
    },
    {
      "title": "Territory Registrations Over Time",
      "description": "Rate of indigenous territory registrations segmented by country of origin",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 8, "x": 0, "y": 7 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "sum(rate(gl_eudr_irc_territories_registered_total{environment=\"$environment\"}[5m])) by (country)", "legendFormat": "{{country}}" },
        { "expr": "sum(rate(gl_eudr_irc_territories_registered_total{environment=\"$environment\"}[5m]))", "legendFormat": "Total" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "drawStyle": "line",
            "pointSize": 5,
            "stacking": { "mode": "none" },
            "spanNulls": false,
            "lineInterpolation": "smooth"
          }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Total" }, "properties": [{ "id": "color", "value": { "fixedColor": "white", "mode": "fixed" } }, { "id": "custom.lineWidth", "value": 3 }, { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 5] } }] }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "title": "FPIC Verifications by Action",
      "description": "Free Prior and Informed Consent verification activity broken down by action type (initial, renewal, update)",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 8, "x": 8, "y": 7 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "sum(rate(gl_eudr_irc_fpic_verifications_total{environment=\"$environment\", action=\"initial\"}[5m]))", "legendFormat": "Initial" },
        { "expr": "sum(rate(gl_eudr_irc_fpic_verifications_total{environment=\"$environment\", action=\"renewal\"}[5m]))", "legendFormat": "Renewal" },
        { "expr": "sum(rate(gl_eudr_irc_fpic_verifications_total{environment=\"$environment\", action=\"update\"}[5m]))", "legendFormat": "Update" },
        { "expr": "sum(rate(gl_eudr_irc_fpic_verifications_total{environment=\"$environment\"}[5m]))", "legendFormat": "Total" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "drawStyle": "line",
            "pointSize": 5,
            "stacking": { "mode": "none" },
            "spanNulls": false,
            "lineInterpolation": "smooth"
          }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Initial" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Renewal" }, "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Update" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Total" }, "properties": [{ "id": "color", "value": { "fixedColor": "white", "mode": "fixed" } }, { "id": "custom.lineWidth", "value": 3 }, { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 5] } }] }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "title": "Overlaps Detected by Type",
      "description": "Supply chain and territory overlap detections categorized by proximity type (direct, partial, adjacent, proximate)",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 8, "x": 16, "y": 7 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "sum(rate(gl_eudr_irc_overlaps_detected_total{environment=\"$environment\", type=\"direct\"}[5m]))", "legendFormat": "Direct" },
        { "expr": "sum(rate(gl_eudr_irc_overlaps_detected_total{environment=\"$environment\", type=\"partial\"}[5m]))", "legendFormat": "Partial" },
        { "expr": "sum(rate(gl_eudr_irc_overlaps_detected_total{environment=\"$environment\", type=\"adjacent\"}[5m]))", "legendFormat": "Adjacent" },
        { "expr": "sum(rate(gl_eudr_irc_overlaps_detected_total{environment=\"$environment\", type=\"proximate\"}[5m]))", "legendFormat": "Proximate" },
        { "expr": "sum(rate(gl_eudr_irc_overlaps_detected_total{environment=\"$environment\"}[5m]))", "legendFormat": "Total" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "drawStyle": "line",
            "pointSize": 5,
            "stacking": { "mode": "normal" },
            "spanNulls": false,
            "lineInterpolation": "smooth"
          }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Direct" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Partial" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Adjacent" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Proximate" }, "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Total" }, "properties": [{ "id": "color", "value": { "fixedColor": "white", "mode": "fixed" } }, { "id": "custom.lineWidth", "value": 3 }, { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 5] } }] }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "title": "Violation Monitoring",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 },
      "collapsed": false,
      "panels": []
    },
    {
      "title": "Violations by Severity",
      "description": "Indigenous rights violations detected over time, broken down by severity level. Alert: critical violations > 5/hour triggers immediate escalation.",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "sum(rate(gl_eudr_irc_violations_detected_total{environment=\"$environment\", severity=\"critical\"}[5m])) * 3600", "legendFormat": "Critical (/hr)" },
        { "expr": "sum(rate(gl_eudr_irc_violations_detected_total{environment=\"$environment\", severity=\"high\"}[5m])) * 3600", "legendFormat": "High (/hr)" },
        { "expr": "sum(rate(gl_eudr_irc_violations_detected_total{environment=\"$environment\", severity=\"medium\"}[5m])) * 3600", "legendFormat": "Medium (/hr)" },
        { "expr": "sum(rate(gl_eudr_irc_violations_detected_total{environment=\"$environment\", severity=\"low\"}[5m])) * 3600", "legendFormat": "Low (/hr)" },
        { "expr": "sum(increase(gl_eudr_irc_violations_detected_total{environment=\"$environment\", severity=\"critical\"}[1h]))", "legendFormat": "Critical (1h count)" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20,
            "drawStyle": "line",
            "pointSize": 5,
            "stacking": { "mode": "none" },
            "spanNulls": false,
            "lineInterpolation": "smooth"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 2 },
              { "color": "red", "value": 5 }
            ]
          }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Critical (/hr)" }, "properties": [{ "id": "color", "value": { "fixedColor": "dark-red", "mode": "fixed" } }, { "id": "custom.lineWidth", "value": 3 }] },
          { "matcher": { "id": "byName", "options": "High (/hr)" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Medium (/hr)" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Low (/hr)" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Critical (1h count)" }, "properties": [{ "id": "color", "value": { "fixedColor": "dark-red", "mode": "fixed" } }, { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 5] } }, { "id": "custom.fillOpacity", "value": 0 }] }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "mean", "max", "last"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "alert": {
        "name": "EUDR-IRC Critical Violations Rate",
        "message": "Critical indigenous rights violations exceed 5/hour threshold. Immediate investigation required.",
        "conditions": [
          {
            "type": "query",
            "query": { "params": ["E", "1h", "now"] },
            "reducer": { "type": "last", "params": [] },
            "evaluator": { "type": "gt", "params": [5] }
          }
        ],
        "frequency": "1m",
        "for": "5m",
        "noDataState": "no_data",
        "executionErrorState": "alerting",
        "notifications": []
      }
    },
    {
      "title": "Unresolved Violations Trend",
      "description": "Trend of unresolved violations over time with severity breakdown. Alert fires when total exceeds 20.",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "sum(gl_eudr_irc_unresolved_violations{environment=\"$environment\"})", "legendFormat": "Total Unresolved" },
        { "expr": "sum(gl_eudr_irc_unresolved_violations{environment=\"$environment\", severity=\"critical\"})", "legendFormat": "Critical" },
        { "expr": "sum(gl_eudr_irc_unresolved_violations{environment=\"$environment\", severity=\"high\"})", "legendFormat": "High" },
        { "expr": "sum(gl_eudr_irc_unresolved_violations{environment=\"$environment\", severity=\"medium\"})", "legendFormat": "Medium" },
        { "expr": "sum(gl_eudr_irc_unresolved_violations{environment=\"$environment\", severity=\"low\"})", "legendFormat": "Low" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "drawStyle": "line",
            "pointSize": 5,
            "stacking": { "mode": "none" },
            "spanNulls": false,
            "lineInterpolation": "smooth"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "orange", "value": 15 },
              { "color": "red", "value": 20 }
            ]
          }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Total Unresolved" }, "properties": [{ "id": "color", "value": { "fixedColor": "white", "mode": "fixed" } }, { "id": "custom.lineWidth", "value": 3 }] },
          { "matcher": { "id": "byName", "options": "Critical" }, "properties": [{ "id": "color", "value": { "fixedColor": "dark-red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "High" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Medium" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Low" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "alert": {
        "name": "EUDR-IRC Unresolved Violations Threshold",
        "message": "Unresolved indigenous rights violations exceed 20. Remediation backlog growing beyond acceptable limit.",
        "conditions": [
          {
            "type": "query",
            "query": { "params": ["A", "5m", "now"] },
            "reducer": { "type": "last", "params": [] },
            "evaluator": { "type": "gt", "params": [20] }
          }
        ],
        "frequency": "5m",
        "for": "10m",
        "noDataState": "no_data",
        "executionErrorState": "alerting",
        "notifications": []
      }
    },
    {
      "title": "Performance Metrics",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 28 },
      "collapsed": false,
      "panels": []
    },
    {
      "title": "Processing Latency (p50 / p95 / p99)",
      "description": "Processing duration distribution by operation. Shows p50, p95, and p99 percentiles. Alert: p99 > 5s indicates performance degradation.",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 29 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(gl_eudr_irc_processing_duration_seconds_bucket{environment=\"$environment\"}[5m])) by (le))", "legendFormat": "p50 (all ops)" },
        { "expr": "histogram_quantile(0.95, sum(rate(gl_eudr_irc_processing_duration_seconds_bucket{environment=\"$environment\"}[5m])) by (le))", "legendFormat": "p95 (all ops)" },
        { "expr": "histogram_quantile(0.99, sum(rate(gl_eudr_irc_processing_duration_seconds_bucket{environment=\"$environment\"}[5m])) by (le))", "legendFormat": "p99 (all ops)" },
        { "expr": "histogram_quantile(0.99, sum(rate(gl_eudr_irc_processing_duration_seconds_bucket{environment=\"$environment\", operation=\"territory_check\"}[5m])) by (le))", "legendFormat": "p99 (territory_check)" },
        { "expr": "histogram_quantile(0.99, sum(rate(gl_eudr_irc_processing_duration_seconds_bucket{environment=\"$environment\", operation=\"fpic_verify\"}[5m])) by (le))", "legendFormat": "p99 (fpic_verify)" },
        { "expr": "histogram_quantile(0.99, sum(rate(gl_eudr_irc_processing_duration_seconds_bucket{environment=\"$environment\", operation=\"overlap_detect\"}[5m])) by (le))", "legendFormat": "p99 (overlap_detect)" },
        { "expr": "histogram_quantile(0.99, sum(rate(gl_eudr_irc_processing_duration_seconds_bucket{environment=\"$environment\", operation=\"violation_scan\"}[5m])) by (le))", "legendFormat": "p99 (violation_scan)" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8,
            "drawStyle": "line",
            "pointSize": 5,
            "stacking": { "mode": "none" },
            "spanNulls": false,
            "lineInterpolation": "smooth",
            "thresholdsStyle": { "mode": "line+area" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "transparent", "value": null },
              { "color": "red", "value": 5 }
            ]
          }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "p50 (all ops)" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "p95 (all ops)" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "p99 (all ops)" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }, { "id": "custom.lineWidth", "value": 3 }] }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "last"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "alert": {
        "name": "EUDR-IRC p99 Latency Threshold",
        "message": "p99 processing latency exceeds 5 seconds. Performance degradation detected in indigenous rights checking pipeline.",
        "conditions": [
          {
            "type": "query",
            "query": { "params": ["C", "5m", "now"] },
            "reducer": { "type": "last", "params": [] },
            "evaluator": { "type": "gt", "params": [5] }
          }
        ],
        "frequency": "1m",
        "for": "5m",
        "noDataState": "no_data",
        "executionErrorState": "alerting",
        "notifications": []
      }
    },
    {
      "title": "Error Rate by Operation",
      "description": "Error rate across all indigenous rights checking operations. Alert: error rate > 1% triggers notification for investigation.",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 29 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
