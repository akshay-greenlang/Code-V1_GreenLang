      "targets": [
        { "expr": "histogram_quantile(0.50, rate(gl_eudr_mbc_overdraft_check_duration_seconds_bucket[5m]))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, rate(gl_eudr_mbc_overdraft_check_duration_seconds_bucket[5m]))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, rate(gl_eudr_mbc_overdraft_check_duration_seconds_bucket[5m]))", "legendFormat": "p99" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "API Errors (1h)",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 20 },
