      "title": "Reconciliation Latency (p50/p95/p99)",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(gl_eudr_mbc_reconciliation_duration_seconds_bucket[5m]))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, rate(gl_eudr_mbc_reconciliation_duration_seconds_bucket[5m]))", "legendFormat": "p95" },
