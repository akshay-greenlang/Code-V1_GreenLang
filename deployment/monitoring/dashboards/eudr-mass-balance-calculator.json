        { "expr": "histogram_quantile(0.95, rate(gl_eudr_mbc_entry_recording_duration_seconds_bucket[5m]))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, rate(gl_eudr_mbc_entry_recording_duration_seconds_bucket[5m]))", "legendFormat": "p99" }
