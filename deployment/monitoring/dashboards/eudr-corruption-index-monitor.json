              { "color": "yellow", "value": 50 },
              { "color": "green", "value": 70 }
            ]
          },
          "unit": "short",
          "min": 0,
          "max": 100
        }
      }
    },
    {
      "title": "High-Risk Country Count",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
