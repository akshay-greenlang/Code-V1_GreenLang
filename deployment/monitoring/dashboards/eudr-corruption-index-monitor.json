        { "expr": "sum(gl_eudr_cim_countries_monitored_total{risk_level=\"high\"})", "legendFormat": "High Risk" },
        { "expr": "sum(gl_eudr_cim_countries_monitored_total{risk_level=\"critical\"})", "legendFormat": "Critical" }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          },
          "unit": "short"
        }
      }
    },
    {
      "title": "Average CPI Score",
