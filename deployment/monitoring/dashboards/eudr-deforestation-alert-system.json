      }
    },
    {
      "title": "Geographic Heatmap",
      "type": "geomap",
      "gridPos": { "h": 10, "w": 6, "x": 18, "y": 17 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(gl_eudr_das_alerts_active_total) by (country_code, latitude, longitude)", "legendFormat": "{{country_code}}", "format": "table", "instant": true }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
