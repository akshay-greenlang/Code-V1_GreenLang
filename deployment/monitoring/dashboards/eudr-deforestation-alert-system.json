              { "color": "orange", "value": 15 },
              { "color": "red", "value": 30 },
              { "color": "dark-red", "value": 50 }
            ]
          },
          "unit": "short"
        }
      },
      "options": {
        "view": {
          "id": "zero",
          "lat": 0,
          "lon": 20,
          "zoom": 2
        },
        "layers": [
          {
            "type": "markers",
            "config": {
              "style": {
                "color": { "field": "Value", "fixed": "dark-green" },
                "opacity": 0.8,
                "size": { "field": "Value", "fixed": 5, "min": 3, "max": 20 }
              }
            }
          }
        ]
      }
