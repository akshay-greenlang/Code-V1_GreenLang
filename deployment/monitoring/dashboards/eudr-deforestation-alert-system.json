{
  "annotations": { "list": [] },
  "description": "AGENT-EUDR-020: Deforestation Alert System Agent -- Satellite detection ingestion, alert lifecycle management, severity scoring, spatial buffer zone monitoring, EUDR cutoff date verification, historical baseline comparisons, workflow state machines, compliance impact assessments, and notification dispatch",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "Overview",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "title": "Active Alerts",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(gl_eudr_das_alerts_active_total)", "legendFormat": "Total Active" },
        { "expr": "sum(gl_eudr_das_alerts_active_total{severity=\"critical\"})", "legendFormat": "Critical" },
        { "expr": "sum(gl_eudr_das_alerts_active_total{severity=\"high\"})", "legendFormat": "High" },
        { "expr": "sum(increase(gl_eudr_das_alerts_created_total[24h]))", "legendFormat": "New (24h)" }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "orange", "value": 25 },
              { "color": "red", "value": 50 }
            ]
          },
          "unit": "short"
        }
      }
    },
    {
      "title": "Detections Today",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(increase(gl_eudr_das_detections_ingested_total[24h]))", "legendFormat": "Detections (24h)" },
        { "expr": "sum(increase(gl_eudr_das_detections_ingested_total{change_type=\"deforestation\"}[24h]))", "legendFormat": "Deforestation (24h)" },
        { "expr": "sum(increase(gl_eudr_das_detections_ingested_total{change_type=\"degradation\"}[24h]))", "legendFormat": "Degradation (24h)" },
        { "expr": "sum(increase(gl_eudr_das_detections_ingested_total{change_type=\"fire\"}[24h]))", "legendFormat": "Fire (24h)" }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "thresholds": {
            "steps": [
              { "color": "blue", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "orange", "value": 500 },
              { "color": "red", "value": 1000 }
            ]
          },
          "unit": "short"
        }
      }
    },
    {
      "title": "Monitored Plots",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(gl_eudr_das_spatial_buffers_active_total)", "legendFormat": "Active Buffers" }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "orange", "value": 50 },
              { "color": "yellow", "value": 200 },
              { "color": "green", "value": 500 }
            ]
          },
          "unit": "short",
          "min": 0,
          "max": 5000
        }
      }
    },
    {
      "title": "SLA Compliance",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "(1 - (sum(gl_eudr_das_sla_breached_total) / clamp_min(sum(gl_eudr_das_alerts_created_total), 1))) * 100", "legendFormat": "SLA Compliance %" }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 1,
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "orange", "value": 80 },
              { "color": "yellow", "value": 90 },
              { "color": "green", "value": 95 }
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      }
    },
    {
      "title": "Satellite Detections",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false,
      "panels": []
    },
    {
      "title": "Detections by Source",
      "type": "piechart",
      "gridPos": { "h": 10, "w": 6, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(increase(gl_eudr_das_detections_ingested_total{source=\"sentinel2\"}[$__range]))", "legendFormat": "Sentinel-2" },
        { "expr": "sum(increase(gl_eudr_das_detections_ingested_total{source=\"landsat8\"}[$__range]))", "legendFormat": "Landsat 8" },
        { "expr": "sum(increase(gl_eudr_das_detections_ingested_total{source=\"landsat9\"}[$__range]))", "legendFormat": "Landsat 9" },
        { "expr": "sum(increase(gl_eudr_das_detections_ingested_total{source=\"glad\"}[$__range]))", "legendFormat": "GLAD" },
        { "expr": "sum(increase(gl_eudr_das_detections_ingested_total{source=\"hansen_gfc\"}[$__range]))", "legendFormat": "Hansen GFC" },
        { "expr": "sum(increase(gl_eudr_das_detections_ingested_total{source=\"radd\"}[$__range]))", "legendFormat": "RADD" },
        { "expr": "sum(increase(gl_eudr_das_detections_ingested_total{source=\"planet\"}[$__range]))", "legendFormat": "Planet" },
        { "expr": "sum(increase(gl_eudr_das_detections_ingested_total{source=\"custom\"}[$__range]))", "legendFormat": "Custom" }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "right" },
        "pieType": "donut"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "title": "Detection Trend",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 6, "x": 6, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(rate(gl_eudr_das_detections_ingested_total[1h])) by (source)", "legendFormat": "{{source}}" },
        { "expr": "sum(rate(gl_eudr_das_detections_ingested_total[1h]))", "legendFormat": "Total" }
