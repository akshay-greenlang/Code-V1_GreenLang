      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "stacking": { "mode": "normal" }
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" }
      }
    },
    {
      "title": "Change Type Distribution",
      "type": "barchart",
      "gridPos": { "h": 10, "w": 6, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(increase(gl_eudr_das_detections_ingested_total[$__range])) by (change_type)", "legendFormat": "{{change_type}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "orange", "value": 500 },
              { "color": "red", "value": 1000 }
            ]
          },
          "unit": "short"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "deforestation" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "degradation" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "fire" }, "properties": [{ "id": "color", "value": { "fixedColor": "dark-red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "logging" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "clearing" }, "properties": [{ "id": "color", "value": { "fixedColor": "semi-dark-orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "regrowth" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "no_change" }, "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }] }
        ]
      },
      "options": {
        "orientation": "horizontal",
        "showValue": "always",
        "barWidth": 0.7
      }
    },
    {
      "title": "Cloud Cover Impact",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 6, "x": 18, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "avg(gl_eudr_das_detection_cloud_cover_pct)", "legendFormat": "Avg Cloud Cover %" },
        { "expr": "quantile(0.90, gl_eudr_das_detection_cloud_cover_pct)", "legendFormat": "P90 Cloud Cover %" },
        { "expr": "avg(gl_eudr_das_detection_confidence)", "legendFormat": "Avg Confidence" }
