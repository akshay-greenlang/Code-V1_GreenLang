      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 12,
      "title": "Report Generation Latency (p50/p95/p99)",
      "description": "Latency percentiles for mitigation report generation including evidence aggregation, effectiveness summaries, and compliance formatting. Target: p99 < 10 seconds.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 43 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(gl_eudr_mmd_report_generation_seconds_bucket{environment=\"$environment\"}[5m])) by (le))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum(rate(gl_eudr_mmd_report_generation_seconds_bucket{environment=\"$environment\"}[5m])) by (le))", "legendFormat": "p95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum(rate(gl_eudr_mmd_report_generation_seconds_bucket{environment=\"$environment\"}[5m])) by (le))", "legendFormat": "p99", "refId": "C" }
