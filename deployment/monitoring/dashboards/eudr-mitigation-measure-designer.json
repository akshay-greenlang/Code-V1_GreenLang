{
  "annotations": { "list": [] },
  "description": "AGENT-EUDR-029: Mitigation Measure Designer (MMD) -- Strategy design linked to risk assessments, Article 11 measure lifecycle management, curated template library, evidence/document collection, effectiveness estimation with conservative/moderate/optimistic projections, post-mitigation verification, workflow state machine, implementation milestone tracking, and audit-ready documentation for EUDR Articles 10, 11, 12, 13, 14-16, 29, 31 compliance",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "Strategy & Measure Operations",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 1,
      "title": "Strategies Designed",
      "description": "Rate of mitigation strategies designed over time by commodity. Each strategy links a risk assessment to a set of Article 11 mitigation measures.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "sum(rate(gl_eudr_mmd_strategies_designed_total{environment=\"$environment\"}[5m])) * 3600", "legendFormat": "Total (/hr)", "refId": "A" },
        { "expr": "sum by (commodity) (rate(gl_eudr_mmd_strategies_designed_total{environment=\"$environment\", commodity=~\"$commodity\"}[5m])) * 3600", "legendFormat": "{{commodity}} (/hr)", "refId": "B" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "drawStyle": "line",
            "pointSize": 5,
            "stacking": { "mode": "none" },
            "spanNulls": false,
            "lineInterpolation": "smooth"
          }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Total (/hr)" }, "properties": [{ "id": "color", "value": { "fixedColor": "white", "mode": "fixed" } }, { "id": "custom.lineWidth", "value": 3 }, { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 5] } }] }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 2,
      "title": "Measures Proposed by Category",
      "description": "Rate of mitigation measures proposed, stacked by Article 11 category. Categories include: additional_information, independent_survey, third_party_verification, supplier_engagement, supply_chain_restructuring, certification, monitoring_system, field_inspection, document_review.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "sum by (category) (rate(gl_eudr_mmd_measures_proposed_total{environment=\"$environment\"}[5m])) * 3600", "legendFormat": "{{category}} (/hr)", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20,
            "drawStyle": "line",
            "pointSize": 5,
            "stacking": { "mode": "normal" },
            "spanNulls": false,
            "lineInterpolation": "smooth"
          },
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "mean"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 3,
      "title": "Measures Approved",
      "description": "Rate of mitigation measures approved for implementation over time. Approval indicates readiness for resource allocation and execution.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "sum(rate(gl_eudr_mmd_measures_approved_total{environment=\"$environment\"}[5m])) * 3600", "legendFormat": "Total Approved (/hr)", "refId": "A" },
        { "expr": "sum by (dimension) (rate(gl_eudr_mmd_measures_approved_total{environment=\"$environment\"}[5m])) * 3600", "legendFormat": "{{dimension}} (/hr)", "refId": "B" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "stacking": { "mode": "none" }
          }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Total Approved (/hr)" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }, { "id": "custom.lineWidth", "value": 3 }] }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 4,
      "title": "Measures Completed",
      "description": "Rate of mitigation measures marked as completed over time. Completion triggers evidence review and effectiveness verification workflows.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "sum(rate(gl_eudr_mmd_measures_completed_total{environment=\"$environment\"}[5m])) * 3600", "legendFormat": "Total Completed (/hr)", "refId": "A" },
        { "expr": "sum by (category) (rate(gl_eudr_mmd_measures_completed_total{environment=\"$environment\"}[5m])) * 3600", "legendFormat": "{{category}} (/hr)", "refId": "B" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "stacking": { "mode": "none" }
          }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Total Completed (/hr)" }, "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }, { "id": "custom.lineWidth", "value": 3 }] }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "title": "Verification & Reporting",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 5,
      "title": "Verifications by Result",
      "description": "Distribution of post-mitigation verification results in the last 24 hours. Effective means target risk score was met; partially_effective means >50% of target achieved.",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "sum(increase(gl_eudr_mmd_verifications_total{environment=\"$environment\", result=\"effective\"}[24h]))", "legendFormat": "Effective", "refId": "A" },
        { "expr": "sum(increase(gl_eudr_mmd_verifications_total{environment=\"$environment\", result=\"partially_effective\"}[24h]))", "legendFormat": "Partially Effective", "refId": "B" },
        { "expr": "sum(increase(gl_eudr_mmd_verifications_total{environment=\"$environment\", result=\"ineffective\"}[24h]))", "legendFormat": "Ineffective", "refId": "C" },
        { "expr": "sum(increase(gl_eudr_mmd_verifications_total{environment=\"$environment\", result=\"inconclusive\"}[24h]))", "legendFormat": "Inconclusive", "refId": "D" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Effective" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Partially Effective" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Ineffective" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Inconclusive" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["value"] },
        "tooltip": { "mode": "single" },
        "pieType": "donut",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "id": 6,
      "title": "Reports Generated",
      "description": "Rate of mitigation reports generated over time by report type. Reports provide Article 11 compliance documentation for DDS submissions.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "sum(rate(gl_eudr_mmd_reports_generated_total{environment=\"$environment\"}[5m])) * 3600", "legendFormat": "Total (/hr)", "refId": "A" },
        { "expr": "sum by (report_type) (rate(gl_eudr_mmd_reports_generated_total{environment=\"$environment\"}[5m])) * 3600", "legendFormat": "{{report_type}} (/hr)", "refId": "B" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "stacking": { "mode": "none" }
          }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Total (/hr)" }, "properties": [{ "id": "custom.lineWidth", "value": 3 }, { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 5] } }] }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "mean"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 7,
      "title": "Workflows Closed",
      "description": "Rate of mitigation workflows closed over time. Workflow closure indicates the full design-implement-verify lifecycle has been completed.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "sum(rate(gl_eudr_mmd_workflows_closed_total{environment=\"$environment\"}[5m])) * 3600", "legendFormat": "Closed (/hr)", "refId": "A" },
        { "expr": "sum(rate(gl_eudr_mmd_workflows_escalated_total{environment=\"$environment\"}[5m])) * 3600", "legendFormat": "Escalated (/hr)", "refId": "B" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "drawStyle": "line",
            "lineInterpolation": "smooth"
          }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Closed (/hr)" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Escalated (/hr)" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 8,
      "title": "API Errors",
      "description": "Rate of API errors (4xx and 5xx) across all /v1/eudr-mmd endpoints. Sustained 5xx error rate > 1% triggers critical alert.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 26 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "sum(rate(gl_eudr_mmd_api_errors_total{environment=\"$environment\", status_code=~\"5..\"}[5m])) * 3600", "legendFormat": "5xx Errors (/hr)", "refId": "A" },
        { "expr": "sum(rate(gl_eudr_mmd_api_errors_total{environment=\"$environment\", status_code=~\"4..\"}[5m])) * 3600", "legendFormat": "4xx Errors (/hr)", "refId": "B" },
        { "expr": "sum(rate(gl_eudr_mmd_api_errors_total{environment=\"$environment\"}[5m])) / (sum(rate(gl_eudr_mmd_api_requests_total{environment=\"$environment\"}[5m])) > 0) * 100", "legendFormat": "Error Rate %", "refId": "C" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "stacking": { "mode": "none" }
          }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "5xx Errors (/hr)" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "4xx Errors (/hr)" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Error Rate %" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }, { "id": "custom.axisPlacement", "value": "right" }, { "id": "unit", "value": "percent" }] }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "title": "Latency Metrics",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 34 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 9,
      "title": "Strategy Design Latency (p50/p95/p99)",
      "description": "Latency percentiles for end-to-end mitigation strategy design. Includes risk analysis, template selection, measure design, and effectiveness estimation. Target: p99 < 5 seconds.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 35 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(gl_eudr_mmd_strategy_design_seconds_bucket{environment=\"$environment\"}[5m])) by (le))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum(rate(gl_eudr_mmd_strategy_design_seconds_bucket{environment=\"$environment\"}[5m])) by (le))", "legendFormat": "p95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum(rate(gl_eudr_mmd_strategy_design_seconds_bucket{environment=\"$environment\"}[5m])) by (le))", "legendFormat": "p99", "refId": "C" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "thresholdsStyle": { "mode": "line" }
          },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 2 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 10,
      "title": "Effectiveness Estimation Latency (p50/p95/p99)",
      "description": "Latency percentiles for effectiveness estimation calculations including conservative/moderate/optimistic projections with applicability and quality factors. Target: p99 < 2 seconds.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 35 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(gl_eudr_mmd_effectiveness_estimation_seconds_bucket{environment=\"$environment\"}[5m])) by (le))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum(rate(gl_eudr_mmd_effectiveness_estimation_seconds_bucket{environment=\"$environment\"}[5m])) by (le))", "legendFormat": "p95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum(rate(gl_eudr_mmd_effectiveness_estimation_seconds_bucket{environment=\"$environment\"}[5m])) by (le))", "legendFormat": "p99", "refId": "C" }
      ],
      "fieldConfig": {
        "defaults": {
