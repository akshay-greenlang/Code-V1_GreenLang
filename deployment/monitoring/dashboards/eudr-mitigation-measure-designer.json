    {
      "title": "Operational Gauges",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 51 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 13,
      "title": "Active Workflows",
      "description": "Current number of active mitigation design workflows (initiated, designing, pending_approval, implementing, monitoring, verifying). Spike > 200% baseline triggers info alert.",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 52 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "sum(gl_eudr_mmd_active_workflows{environment=\"$environment\"})", "legendFormat": "Active Workflows", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "orange", "value": 100 },
              { "color": "red", "value": 200 }
            ]
          },
          "unit": "short"
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "id": 14,
      "title": "Overdue Measures",
      "description": "Current number of overdue mitigation measures (past deadline, not yet completed). Non-zero triggers warning alert. > 10 triggers critical.",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 52 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "sum(gl_eudr_mmd_overdue_measures{environment=\"$environment\"})", "legendFormat": "Overdue Measures", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "orange", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          },
          "unit": "short"
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "id": 15,
      "title": "Average Risk Reduction",
      "description": "Average post-mitigation risk reduction percentage across all verified strategies. Target: >= 40% reduction for Article 11 compliance. Higher values indicate more effective mitigation portfolio.",
