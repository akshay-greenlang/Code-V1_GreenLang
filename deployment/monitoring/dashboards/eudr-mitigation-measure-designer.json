      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 52 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "avg(gl_eudr_mmd_avg_risk_reduction{environment=\"$environment\"}) or vector(0)", "legendFormat": "Avg Risk Reduction %", "refId": "A" }
