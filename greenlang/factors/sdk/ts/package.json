{
  "name": "@greenlang/factors",
  "version": "1.3.0",
  "description": "GreenLang Factors API client - typed TypeScript / Node SDK for the global emission-factor catalog (search, resolve, edition pinning, signed-receipt verification).",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "default": "./dist/esm/index.js"
    },
    "./verify": {
      "types": "./dist/types/verify.d.ts",
      "import": "./dist/esm/verify.js",
      "require": "./dist/cjs/verify.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "bin": {
    "glfactors": "dist/cjs/cli.js"
  },
  "scripts": {
    "build": "npm run build:esm && npm run build:cjs && npm run build:types",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build:types": "tsc -p tsconfig.json --emitDeclarationOnly --declaration --declarationDir dist/types",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "jest --config jest.config.js",
    "test:watch": "jest --watch",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run clean && npm run build && npm test"
  },
  "keywords": [
    "greenlang",
    "factors",
    "emission-factors",
    "ghg",
    "ghg-protocol",
    "carbon",
    "carbon-accounting",
    "sustainability",
    "climate",
    "esg",
    "scope-1",
    "scope-2",
    "scope-3",
    "cbam",
    "iso-14064",
    "iso-14083",
    "pcaf",
    "api-client",
    "sdk",
    "typescript"
  ],
  "author": {
    "name": "GreenLang",
    "email": "support@greenlang.io",
    "url": "https://greenlang.io"
  },
  "license": "MIT",
  "homepage": "https://developers.greenlang.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/greenlang/greenlang.git",
    "directory": "greenlang/factors/sdk/ts"
  },
  "bugs": {
    "url": "https://github.com/greenlang/greenlang/issues",
    "email": "support@greenlang.io"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {},
  "peerDependencies": {
    "jose": ">=5.0.0",
    "undici": ">=5"
  },
  "peerDependenciesMeta": {
    "jose": {
      "optional": true
    },
    "undici": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "jest": "^29.7.0",
    "jose": "^5.2.0",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.2",
    "typescript": "^5.4.0"
  }
}
