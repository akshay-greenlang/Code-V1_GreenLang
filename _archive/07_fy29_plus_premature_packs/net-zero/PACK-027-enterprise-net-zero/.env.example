# PACK-027: Enterprise Net Zero Pack - Environment Configuration
# =================================================================
#
# Copy this file to .env and configure with your actual values.
#
# Author: GreenLang Platform Team
# Date: March 2026

# ================
# Pack Configuration
# ================
PACK_ID=PACK-027
PACK_NAME="Enterprise Net Zero Pack"
PACK_VERSION=1.0.0
PACK_PRESET=manufacturing  # Options: financial_services, manufacturing, technology, energy_utilities, retail_consumer, healthcare, transportation_logistics, real_estate

# ================
# Server Configuration
# ================
PORT=8000
MAX_WORKERS=8
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
CORS_ORIGINS=*  # Comma-separated list or * for all

# ================
# Database Configuration
# ================
DATABASE_URL=postgresql://greenlang:greenlang@localhost:5432/greenlang
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30

# ================
# Redis Configuration
# ================
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=50

# ================
# Security Configuration
# ================
SECRET_KEY=CHANGE_ME_TO_RANDOM_STRING
JWT_SECRET_KEY=CHANGE_ME_TO_RANDOM_STRING
JWT_ALGORITHM=RS256
JWT_EXPIRATION_MINUTES=60

# Vault Configuration
VAULT_URL=http://localhost:8200
VAULT_TOKEN=CHANGE_ME

# ================
# Enterprise System Integrations
# ================

# SAP Integration
SAP_ENABLED=false
SAP_HOST=sap.example.com
SAP_PORT=443
SAP_CLIENT=100
SAP_USER=CHANGE_ME
SAP_PASSWORD=CHANGE_ME
SAP_SYSTEM_ID=PRD

# Oracle Integration
ORACLE_ENABLED=false
ORACLE_HOST=oracle.example.com
ORACLE_PORT=1521
ORACLE_SERVICE_NAME=ORCL
ORACLE_USER=CHANGE_ME
ORACLE_PASSWORD=CHANGE_ME

# Workday Integration
WORKDAY_ENABLED=false
WORKDAY_TENANT=CHANGE_ME
WORKDAY_API_URL=https://wd2-impl.workday.com
WORKDAY_USERNAME=CHANGE_ME
WORKDAY_PASSWORD=CHANGE_ME

# Salesforce Integration
SALESFORCE_ENABLED=false
SALESFORCE_USERNAME=CHANGE_ME
SALESFORCE_PASSWORD=CHANGE_ME
SALESFORCE_SECURITY_TOKEN=CHANGE_ME
SALESFORCE_DOMAIN=login  # or test for sandbox

# ServiceNow Integration
SERVICENOW_ENABLED=false
SERVICENOW_INSTANCE=CHANGE_ME
SERVICENOW_USERNAME=CHANGE_ME
SERVICENOW_PASSWORD=CHANGE_ME

# Tableau Integration
TABLEAU_ENABLED=false
TABLEAU_SERVER=https://tableau.example.com
TABLEAU_USERNAME=CHANGE_ME
TABLEAU_PASSWORD=CHANGE_ME
TABLEAU_SITE_ID=default

# Power BI Integration
POWERBI_ENABLED=false
POWERBI_TENANT_ID=CHANGE_ME
POWERBI_CLIENT_ID=CHANGE_ME
POWERBI_CLIENT_SECRET=CHANGE_ME
POWERBI_WORKSPACE_ID=CHANGE_ME

# Snowflake Integration
SNOWFLAKE_ENABLED=false
SNOWFLAKE_ACCOUNT=CHANGE_ME
SNOWFLAKE_USER=CHANGE_ME
SNOWFLAKE_PASSWORD=CHANGE_ME
SNOWFLAKE_WAREHOUSE=CHANGE_ME
SNOWFLAKE_DATABASE=CHANGE_ME
SNOWFLAKE_SCHEMA=CHANGE_ME

# Databricks Integration
DATABRICKS_ENABLED=false
DATABRICKS_HOST=https://dbc-xxxxx.cloud.databricks.com
DATABRICKS_TOKEN=CHANGE_ME
DATABRICKS_CLUSTER_ID=CHANGE_ME

# ================
# External Service Integrations
# ================

# CDP (Carbon Disclosure Project)
CDP_ENABLED=false
CDP_API_URL=https://api.cdp.net/v2
CDP_API_KEY=CHANGE_ME
CDP_ORGANIZATION_ID=CHANGE_ME

# SBTi Portal
SBTI_ENABLED=false
SBTI_API_URL=https://sciencebasedtargets.org/api
SBTI_API_KEY=CHANGE_ME
SBTI_COMPANY_ID=CHANGE_ME

# SEC EDGAR (for regulatory filings)
SEC_EDGAR_ENABLED=false
SEC_EDGAR_CIK=CHANGE_ME  # Central Index Key
SEC_EDGAR_USER_AGENT=CHANGE_ME@example.com

# Assurance Provider API (e.g., Deloitte, PwC, KPMG, EY)
ASSURANCE_PROVIDER_ENABLED=false
ASSURANCE_PROVIDER_API_URL=https://assurance-api.example.com
ASSURANCE_PROVIDER_API_KEY=CHANGE_ME
ASSURANCE_PROVIDER_COMPANY_ID=CHANGE_ME

# ================
# Observability Configuration
# ================

# Prometheus
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# OpenTelemetry
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=pack-027-enterprise
OTEL_TRACES_SAMPLER=always_on

# Grafana
GRAFANA_ENABLED=true
GRAFANA_URL=http://localhost:3000
GRAFANA_API_KEY=CHANGE_ME

# ================
# Feature Flags
# ================
FEATURE_SCENARIO_MODELING=true
FEATURE_CARBON_PRICING=true
FEATURE_SCOPE4_AVOIDED_EMISSIONS=true
FEATURE_SUPPLY_CHAIN_MAPPING=true
FEATURE_EXTERNAL_ASSURANCE=true
FEATURE_REGULATORY_FILING=true

# ================
# Performance Configuration
# ================
CACHE_TTL_SECONDS=3600
MAX_ENTITIES_PER_CONSOLIDATION=1000
SCENARIO_MONTE_CARLO_ITERATIONS=10000
DATA_QUALITY_CHECK_INTERVAL_HOURS=24

# ================
# Email Configuration (for notifications)
# ================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=CHANGE_ME
SMTP_PASSWORD=CHANGE_ME
SMTP_FROM_EMAIL=pack027@greenlang.io
SMTP_USE_TLS=true

# ================
# Storage Configuration
# ================
S3_BUCKET=greenlang-pack027
S3_REGION=us-east-1
S3_ACCESS_KEY=CHANGE_ME
S3_SECRET_KEY=CHANGE_ME

# Azure Blob Storage (alternative to S3)
AZURE_STORAGE_ACCOUNT=CHANGE_ME
AZURE_STORAGE_KEY=CHANGE_ME
AZURE_STORAGE_CONTAINER=pack027

# ================
# Compliance & Audit
# ================
AUDIT_LOG_ENABLED=true
AUDIT_LOG_LEVEL=INFO
PII_DETECTION_ENABLED=true
DATA_RESIDENCY_REGION=US  # US, EU, APAC
RETENTION_POLICY_DAYS=2555  # 7 years

# ================
# Development/Testing
# ================
DEBUG_MODE=false
ENABLE_SWAGGER=true
ENABLE_REDOC=true
RATE_LIMIT_PER_MINUTE=100

# ================
# Kubernetes Deployment
# ================
K8S_NAMESPACE=greenlang-enterprise
K8S_REPLICAS=3
K8S_CPU_REQUEST=1000m
K8S_CPU_LIMIT=2000m
K8S_MEMORY_REQUEST=2Gi
K8S_MEMORY_LIMIT=4Gi
