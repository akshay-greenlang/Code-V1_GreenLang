            "scope_applicability": { "$ref": "#/properties/parameters/properties/scope_applicability" },
            "uncertainty_low": { "$ref": "#/properties/parameters/properties/uncertainty_low" },
            "uncertainty_high": { "$ref": "#/properties/parameters/properties/uncertainty_high" },
            "land_use_category": {
              "type": "string",
              "maxLength": 128,
              "description": "IPCC land-use category (e.g., 'forest_land', 'cropland', 'grassland', 'wetlands', 'settlements', 'other_land')."
            },
            "sequestration_basis": {
              "type": "string",
              "enum": ["stock_change", "flux", "gain_loss", "tier1_default", "tier3_model"]
            },
            "permanence_class": {
              "type": ["string", "null"],
              "enum": ["short_term", "medium_term", "long_term", "permanent", null]
            },
            "reversal_risk_flag": {
              "type": "boolean",
              "default": false
            },
            "biogenic_accounting_treatment": {
              "type": ["string", "null"],
              "enum": ["zero_rated", "separate_reporting", "included_in_co2e", null]
            }
          }
        }
      }
    },
    {
      "title": "finance_proxies parameters",
      "properties": {
        "factor_family": { "const": "finance_proxies" },
