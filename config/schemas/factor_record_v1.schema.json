              "type": "string",
              "maxLength": 64,
              "description": "Refrigerant gas code (e.g., 'R-134a', 'R-410A', 'HFC-32', 'CO2', 'NH3')."
            },
            "leakage_basis": {
              "type": "string",
              "enum": ["annual", "charge", "disposal"]
            },
            "recharge_assumption": {
              "type": ["number", "null"],
              "minimum": 0,
              "maximum": 1,
              "description": "Annual recharge rate as fraction of full charge."
            },
            "recovery_destruction_treatment": {
              "type": ["string", "null"],
              "enum": ["none", "partial_recovery", "full_recovery", "destroyed", null]
            },
            "gwp_set_mapping": {
              "type": ["string", "null"],
              "enum": ["IPCC_AR4_100", "IPCC_AR5_100", "IPCC_AR5_20", "IPCC_AR6_100", "IPCC_AR6_20", "Kyoto_SAR_100", null]
            }
          }
        }
      }
    },
    {
      "title": "land_removals parameters",
      "properties": {
        "factor_family": { "const": "land_removals" },
