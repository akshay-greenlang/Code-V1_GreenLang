          "properties": {
            "scope_applicability": { "$ref": "#/properties/parameters/properties/scope_applicability" },
            "uncertainty_low": { "$ref": "#/properties/parameters/properties/uncertainty_low" },
            "uncertainty_high": { "$ref": "#/properties/parameters/properties/uncertainty_high" },
            "asset_class": {
              "type": "string",
              "maxLength": 128,
              "description": "PCAF asset class (e.g., 'listed_equity_and_corporate_bonds', 'business_loans_and_unlisted_equity', 'project_finance', 'commercial_real_estate', 'mortgages', 'motor_vehicle_loans', 'sovereign_debt')."
            },
            "sector_code": {
              "type": ["string", "null"],
              "maxLength": 64,
              "description": "Sector code (typically NAICS or ISIC)."
