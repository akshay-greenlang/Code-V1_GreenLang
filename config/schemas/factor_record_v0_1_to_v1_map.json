{
  "$comment": "Field-by-field mapping between factor_record_v0_1 (alpha, frozen 2026-04-25) and factor_record_v1 (forward schema, frozen 2026-04-22). Use as a migration cheatsheet for parsers and tests. Schema status legend: same | renamed | type-narrowed | new_in_v0_1 | omitted_in_v0_1.",
  "v0_1_id": "https://schemas.greenlang.io/factors/factor_record_v0_1.schema.json",
  "v1_id": "https://schemas.greenlang.io/factors/factor_record_v1.schema.json",
  "mapping": {
    "urn":                 {"v1": "factor_id",                        "status": "renamed",        "transform": "coerce_factor_id_to_urn(factor_id, source, namespace, version)"},
    "factor_id_alias":     {"v1": "factor_id",                        "status": "kept_as_alias",  "transform": "identity (string EF:...)"},
    "source_urn":          {"v1": "source_id",                        "status": "renamed",        "transform": "f'urn:gl:source:{slugify(source_id)}'"},
    "factor_pack_urn":     {"v1": null,                                "status": "new_in_v0_1",   "transform": "derived from source_urn + source_version + factor_pack_id"},
    "name":                {"v1": "factor_name",                      "status": "renamed",        "transform": "identity"},
    "description":         {"v1": null,                                "status": "new_in_v0_1",   "transform": "auto-generated from boundary + parameters; required ≥30 chars"},
    "category":            {"v1": "factor_family",                    "status": "type-narrowed", "transform": "factor_family ∈ {combustion} → 'fuel'; {electricity} → 'grid_intensity' or 'scope2_*'; {refrigerants} → 'refrigerant'; {classification_mapping with eu_cbam} → 'cbam_default'; otherwise pending v0.2 extension"},
    "value":               {"v1": "numerator (per-gas dict)",         "status": "type-narrowed", "transform": "numerator.co2e (alpha collapses to scalar; multi-gas split deferred to v0.5)"},
    "unit_urn":            {"v1": "denominator.unit",                 "status": "type-narrowed", "transform": "f'urn:gl:unit:{denominator.unit}'"},
    "gwp_basis":           {"v1": "gwp_set",                          "status": "type-narrowed", "transform": "gwp_set must == 'ar6'; AR4/AR5 records rejected in alpha"},
    "gwp_horizon":         {"v1": null,                                "status": "new_in_v0_1",   "transform": "default 100"},
    "geography_urn":       {"v1": "jurisdiction",                     "status": "renamed",        "transform": "jurisdiction.country='IN' → 'urn:gl:geo:country:in'; eGRID subregion → 'urn:gl:geo:grid_zone:egrid-<sub>'"},
    "vintage_start":       {"v1": "valid_from",                       "status": "renamed",        "transform": "identity (date)"},
    "vintage_end":         {"v1": "valid_to",                         "status": "renamed",        "transform": "identity (date)"},
    "resolution":          {"v1": null,                                "status": "new_in_v0_1",   "transform": "default 'annual'; refrigerants 'point-in-time'"},
    "methodology_urn":     {"v1": "method_profile",                   "status": "renamed",        "transform": "method_profile='corporate_scope1' → 'urn:gl:methodology:ghgp-corporate-scope1'; 'corporate_scope2_location_based' → 'urn:gl:methodology:ghgp-corporate-scope2-location'; 'eu_cbam' → 'urn:gl:methodology:eu-cbam-default'"},
    "boundary":            {"v1": "parameters.boundary",              "status": "renamed",        "transform": "promote nested parameters.boundary → top-level"},
    "uncertainty":         {"v1": "quality.uncertainty",              "status": "type-narrowed", "transform": "optional in alpha; required v0.9+"},
    "licence":              {"v1": "licensing.license_name",           "status": "renamed",        "transform": "identity (SPDX or proprietary tag)"},
    "licence_constraints": {"v1": "licensing.constraints",            "status": "renamed",        "transform": "optional"},
    "citations":           {"v1": null,                                "status": "new_in_v0_1",   "transform": "minimum 1 entry; auto-populate from source_registry citation_text + source_url"},
    "tags":                {"v1": "tags",                              "status": "same",           "transform": "identity"},
    "supersedes_urn":      {"v1": null,                                "status": "new_in_v0_1",   "transform": "set on revisions only"},
    "published_at":        {"v1": "lineage.approved_at",              "status": "renamed",        "transform": "semantic shift: alpha treats published_at as the moment the methodology lead flipped staging→prod"},
    "deprecated_at":       {"v1": "deprecated_at",                    "status": "same",           "transform": "identity"},
    "extraction":          {"v1": "lineage",                           "status": "renamed_and_expanded", "transform": "see extraction.* sub-field rows below; v0.1 promotes nested lineage fields to top-level extraction object and adds raw_artifact_uri/sha256, parser_commit, operator"},
    "review":              {"v1": "lineage (review subset)",           "status": "renamed",        "transform": "see review.* sub-field rows below; v0.1 splits the lineage review fields into a dedicated review object with explicit allOf gates for approved/rejected"},
    "extraction.source_url":         {"v1": "lineage.source.url",                  "status": "promoted",   "transform": "promote nested → required"},
    "extraction.source_record_id":   {"v1": "lineage.raw_record_ref",              "status": "renamed",    "transform": "identity"},
    "extraction.source_publication": {"v1": "lineage.source.publication",          "status": "promoted",   "transform": "promote nested → required"},
    "extraction.source_version":     {"v1": "source_version",                       "status": "renamed",    "transform": "identity"},
    "extraction.raw_artifact_uri":   {"v1": null,                                    "status": "new_in_v0_1","transform": "S3 URI to immutable raw artefact; populated by ingestion pipeline"},
    "extraction.raw_artifact_sha256":{"v1": null,                                    "status": "new_in_v0_1","transform": "sha256(raw artefact bytes)"},
    "extraction.parser_id":          {"v1": "lineage.parser_module",                "status": "renamed",    "transform": "dotted Python path"},
    "extraction.parser_version":     {"v1": "lineage.parser_version",               "status": "same",       "transform": "semver"},
    "extraction.parser_commit":      {"v1": null,                                    "status": "new_in_v0_1","transform": "git commit SHA at extraction time"},
    "extraction.row_ref":            {"v1": "lineage.row_ref",                      "status": "same",       "transform": "identity"},
    "extraction.ingested_at":        {"v1": "lineage.ingested_at",                  "status": "same",       "transform": "identity"},
    "extraction.operator":           {"v1": null,                                    "status": "new_in_v0_1","transform": "'bot:parser_<id>' or 'human:<email>'"},
    "review.review_status":          {"v1": "status",                                "status": "type-narrowed","transform": "v1 status ∈ {draft,under_review,active,deprecated,retired}; v0.1 review.review_status ∈ {pending,approved,rejected}; mapping: draft|under_review→pending; active→approved; deprecated|retired→approved + deprecated_at"},
    "review.reviewer":               {"v1": "lineage.reviewer",                     "status": "renamed",    "transform": "identity (email)"},
    "review.reviewed_at":            {"v1": "lineage.reviewed_at",                  "status": "renamed",    "transform": "identity"},
    "review.approved_by":            {"v1": "lineage.approved_by",                  "status": "renamed",    "transform": "identity"},
    "review.approved_at":            {"v1": "lineage.approved_at",                  "status": "renamed",    "transform": "identity"},
    "review.diff_from_source_uri":   {"v1": null,                                    "status": "new_in_v0_1","transform": "optional"},
    "review.rejection_reason":       {"v1": null,                                    "status": "new_in_v0_1","transform": "required when status=rejected"}
  },
  "v1_fields_intentionally_omitted_in_v0_1": [
    {"field": "activity_schema",                 "reason": "/v1/resolve endpoint deferred to v0.5"},
    {"field": "numerator (per-gas split)",       "reason": "multi-gas + GWP-set switching deferred to v0.5"},
    {"field": "denominator (full object)",       "reason": "alpha uses scalar value + unit_urn"},
    {"field": "parameters (factor_family discriminator)", "reason": "no factor-family discriminator in alpha"},
    {"field": "quality.composite_fqs",           "reason": "FQS dashboard not shipped in alpha"},
    {"field": "quality.pedigree_*",              "reason": "FQS axes not shipped in alpha"},
    {"field": "explainability.*",                "reason": "/v1/factors/{urn}/explain deferred to v0.5"},
    {"field": "licensing.redistribution_class",  "reason": "no commercial tier in alpha"},
    {"field": "licensing.customer_entitlement_required", "reason": "no OEM in alpha"},
    {"field": "lineage.previous_factor_version", "reason": "signed receipts deferred to v0.5"}
  ],
  "alpha_publisher_required_actions": [
    "Use coerce_factor_id_to_urn() to lift EF: ids into urn:gl:factor:... (task #15)",
    "Populate every extraction.* field; reject records with missing parser_commit or raw_artifact_sha256 (task #5 Alpha Provenance Gate)",
    "Set review.review_status='pending' on initial extract; methodology lead flips to 'approved' through staging→prod runbook (task #23)",
    "Reject any record where gwp_basis != 'ar6' (alpha is AR6-only)",
    "Auto-generate citations from source_registry.yaml when source publishes a citable artefact"
  ]
}
