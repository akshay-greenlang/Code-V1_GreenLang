{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "types": ["vite/client", "node"],
    "baseUrl": ".",
    "paths": {
      "@greenlang/shell-ui": ["packages/shell-ui/src/index.ts"]
    }
  },
  "include": ["src", "vite.config.ts", "packages/shell-ui/src", ".storybook", "e2e", "playwright.config.ts"]
}
